{
  "$schema": "node_modules/wrangler/config-schema.json",
  "account_id": "6972c532d902c84b1793316ed3497124",
  "name": "kinexis-digital",
  "main": ".open-next/worker.js",
  "workers_dev": false,
  "compatibility_date": "2025-04-01",
  "compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
  "limits": {
    "cpu_ms": 300000
  },
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "services": [
    {
      "binding": "WORKER_SELF_REFERENCE",
      "service": "kinexis-digital"
    }
  ],
  "routes": [
    {
      "pattern": "kinexisdigital.com",
      "custom_domain": true
    },
    {
      "pattern": "www.kinexisdigital.com",
      "custom_domain": true
    }
  ]
}
