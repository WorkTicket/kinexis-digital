{
  "name": "kinexis-digital-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:design": "node scripts/lint-design-system.mjs",
    "optimize-images": "node scripts/optimize-images.mjs",
    "generate-favicons": "node scripts/generate-favicons.mjs",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "analyze": "set ANALYZE=true && next build",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "cf-security": "node scripts/cloudflare-security-setup.mjs",
    "setup:indexnow": "node scripts/setup-indexnow.mjs",
    "audit:phase9": "node scripts/phase9-sitemap-audit.mjs",
    "audit:phase10": "node scripts/phase10-performance-audit.mjs --save-json",
    "audit:alt-text": "node scripts/phase-alt-text-audit.mjs",
    "submit:indexnow": "node scripts/submit-indexnow.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "browserslist": [
    "chrome >= 111",
    "firefox >= 111",
    "safari >= 16.4",
    "edge >= 111"
  ],
  "overrides": {
    "postcss": "^8.5.10"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.19.11",
    "@sentry/nextjs": "^10.60.0",
    "clsx": "^2.1.1",
    "framer-motion": "^11.0.0",
    "lucide-react": "^0.400.0",
    "next": "^15.0.0",
    "next-intl": "^4.13.0",
    "nodemailer": "^9.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.9",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.10",
    "schema-dts": "^2.0.0",
    "sharp": "^0.35.2",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.10",
    "wrangler": "^4.104.0"
  }
}
