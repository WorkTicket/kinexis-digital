# Contact form — Gmail SMTP (sending account)
# Generate an App Password at: https://myaccount.google.com/apppasswords
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Receives contact form and lead magnet submissions
CONTACT_TO_EMAIL=hello@kinexisdigital.com

# Analytics (loaded only after cookie consent)
NEXT_PUBLIC_GA_ID=G-Z8245BRX2L
# Optional: Microsoft Clarity project ID from clarity.microsoft.com
NEXT_PUBLIC_CLARITY_ID=

# Error monitoring (optional)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# Canonical site URL — use www; set apex → www redirect in Cloudflare
NEXT_PUBLIC_SITE_URL=https://www.kinexisdigital.com

# Cloudflare Pages: add all variables above in Workers & Pages → Settings → Environment variables
# Build command: npm run build
# Output: use @cloudflare/next-on-pages or OpenNext adapter for API routes (/api/contact, /api/lead)
