# =============================================================================
# Required — Production Environment
# =============================================================================

# Site URL (must include protocol, no trailing slash)
NEXT_PUBLIC_SITE_URL=https://www.kinexisdigital.com

# Google Search Console verification token
NEXT_PUBLIC_GSC_VERIFICATION=

# Email delivery (Gmail SMTP via nodemailer)
CONTACT_TO_EMAIL=hello@kinexisdigital.com
GMAIL_USER=
GMAIL_APP_PASSWORD=

# =============================================================================
# Optional — Analytics & Monitoring
# =============================================================================

# Google Analytics 4 measurement ID (format: G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=

# Microsoft Clarity tracking ID
NEXT_PUBLIC_CLARITY_ID=

# Sentry error monitoring (org + project required for source maps upload)
SENTRY_ORG=
SENTRY_PROJECT=
NEXT_PUBLIC_SENTRY_DSN=

# =============================================================================
# Optional — SEO & Maintenance
# =============================================================================

# IndexNow — run: node scripts/setup-indexnow.mjs
# Creates public/{KEY}.txt and indexnow.public.json; adds INDEXNOW_KEY to .dev.vars
# Production: npx wrangler secret put INDEXNOW_KEY
INDEXNOW_KEY=

# PageSpeed Insights API — higher quota for phase10 audit
# Get key: https://developers.google.com/speed/docs/insights/v5/get-started
GOOGLE_PSI_API_KEY=

# =============================================================================
# Infrastructure — Cloudflare Setup (Production)
# =============================================================================

# Rate limiter: uses Cloudflare KV when available, falls back to in-memory Map.
# 1. Create KV namespace in Cloudflare Dashboard: Workers & Pages > KV
#    Name it "kinexis-rate-limit" (or similar)
# 2. Copy the KV namespace ID into wrangler.jsonc under kv_namespaces[0].id
# 3. Run: npx wrangler secret put RATE_LIMIT_KV_ID --env production
# 4. Run: npm run cf-typegen  -- regenerates cloudflare-env.d.ts
# See: https://developers.cloudflare.com/kv/

# =============================================================================
# Development Only
# =============================================================================

# Cloudflare AI Gateway (optional, for dev caching)
# NEXT_PUBLIC_CLOUDFLARE_AI_GATEWAY=
