# Contact form — Gmail SMTP (sending account)
# Generate an App Password at: https://myaccount.google.com/apppasswords
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Receives contact form and lead magnet submissions
CONTACT_TO_EMAIL=hello@kinexisdigital.com

# Analytics (Consent Mode v2 — gtag loads always; data sent only after cookie accept)
NEXT_PUBLIC_GA_ID=G-Z8245BRX2L
# Google Search Console HTML tag verification (DNS TXT also configured on kinexisdigital.com)
NEXT_PUBLIC_GSC_VERIFICATION=7uGCkyYE9LslqA7saQP7jpc0HrzVlVZvds1YX02sr6Q
# Optional: Microsoft Clarity project ID from clarity.microsoft.com
NEXT_PUBLIC_CLARITY_ID=

# Error monitoring (optional)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# Canonical site URL — use www; set apex → www redirect in Cloudflare
NEXT_PUBLIC_SITE_URL=https://www.kinexisdigital.com

# Cloudflare Workers (OpenNext): Workers & Pages → kinexis-digital → Settings
# Runtime vars: GMAIL_USER, GMAIL_APP_PASSWORD (Secret), CONTACT_TO_EMAIL
# Build + runtime: NEXT_PUBLIC_SITE_URL, NEXT_PUBLIC_GA_ID, NEXT_PUBLIC_CLARITY_ID (optional)
# Local preview: copy values to .dev.vars (see OpenNext docs)
# Deploy: npm run deploy | CI deploy command: npm run deploy
