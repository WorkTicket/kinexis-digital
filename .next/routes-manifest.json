    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    },
    {
      "source": "/:locale(en|es)/services/cro",
      "destination": "/:locale/services/funnels",
      "statusCode": 308,
      "regex": "^(?!/_next)(?:/(en|es))/services/cro(?:/)?$"
    },
    {
      "source": "/:locale(en|es)/pricing/cro",
      "destination": "/:locale/pricing/funnels",
