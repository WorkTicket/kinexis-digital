14:["$","$L1a",null,{"slug":"video-marketing","locale":"en","data":{"slug":"video-marketing","locale":"en","visualVariant":"mockup","visualizationSection":"VideoProduction","hero":{"label":"Video Marketing Services","line1":"Video built for","line2":"where it actually runs.","subtitle":"Script, shoot, edit, distribute. Short-form for ads and social. Long-form for your site and email. Each piece built around one clear message, formatted for the channel where it runs.","ctaLabel":"Start Your Video Strategy"},"sectionOrder":["ServiceOverview","WhyKinexus","VideoProduction","VideoDistribution","VideoStrategy","Process","Deliverables","Proof","Results","PricingTeaser"],"overview":{"headline":"Most business video tries to say everything at once","problem":"Video wins attention on every platform, but long, unfocused pieces hurt brand perception and ad performance. Without a distribution plan, content sits on YouTube while creative goes stale.","solution":"One message per video, sized for the channel","problemPoints":["One video attempts to cover the whole company instead of making a single point.","Quality swings from shoot to shoot, which makes ads and social feel disconnected.","Finished files never get cut for ads, email, or the homepage.","New ad creative is slow or expensive, so campaigns fatigue in a few weeks."],"solutionPoints":["Formats matched to platform: vertical for social, horizontal for YouTube, short cuts for ads.","Scripts built around one takeaway and a clear CTA at the end.","Production workflows that yield multiple cuts from a single shoot.","Distribution planning so video reaches ads, social, email, and your website."]},"whyKinexus":{"headline":"What Makes Kinexus Video Different","points":[{"title":"Conversion-first scripts","description":"Every video maps to a funnel stage and a CTA. Brand montages are fine for the about page, not for paid spend."},{"title":"Repurposing built in","description":"One shoot produces ad cuts, social clips, email embeds, and landing page assets. Production cost spreads across channels."},{"title":"Platform-native formats","description":"Vertical for Reels, square for feed, long-form for YouTube. Same message, right dimensions per channel."},{"title":"Performance tracking","description":"View-through, engagement, and pipeline attribution on every asset. We know which video booked the call."}]},"proof":{"caseStudy":{"client":"SaaS Platform","challenge":"Product demo videos looked polished but didn't drive demo bookings or pipeline influence.","outcome":"5.9× demo growth after shifting video strategy to customer story format with clear CTA.","href":"/case-studies/saas-platform-growth"}},"results":{"title":"Results we track","subtitle":"Video performance from recent productions.","metrics":[{"metric":"3.2x","label":"higher engagement vs. static ads"},{"metric":"65%","label":"avg. video completion rate · optimized cuts"},{"metric":"+140%","label":"conversion rate · video vs. text landing pages"}]},"process":{"title":"The production process.","subtitle":"From concept to final delivery,|with a workflow we've refined over time.","steps":[{"title":"Strategy & Concept","desc":"Define goal, audience, platform, and key message before a single frame is shot.","metric":"Creative brief delivered in 3 days"},{"title":"Scripting & Storyboard","desc":"Every video starts with a script and storyboard. Iterate until the narrative arc feels right.","metric":"Script approved before production"},{"title":"Production & Filming","desc":"On-location or remote with professional equipment. We handle all coordination.","metric":"Avg. 2-day shoot turnaround"},{"title":"Post-Production","desc":"Editing, color grading, sound design, motion graphics, captions, platform formatting.","metric":"Delivered in all platform formats"},{"title":"Distribution & Analysis","desc":"Assets delivered in all formats. Track view-through, engagement, and conversion attribution.","metric":"4.2x avg. view-through rate"}]},"deliverables":{"title":"What you get with video marketing","subtitle":"Concept, scripting, production, editing, and multi-format exports for every channel you run.","items":[{"title":"Video Strategy and Content Plan","description":"Video types, platform mapping, messaging themes, and production calendar."},{"title":"Scriptwriting and Storyboarding","description":"Scripts, shot lists, and storyboards approved before production begins."},{"title":"Production Coordination","description":"On-location or remote recording with professional lighting, audio, and direction."},{"title":"Editing and Post-Production","description":"Cuts, captions, graphics, music licensing, and color grading for polished final files."},{"title":"Platform-Optimized Exports","description":"Multiple aspect ratios and lengths formatted for ads, social, web, and email."},{"title":"Performance Tracking Setup","description":"View counts, engagement, click-throughs, and ad performance tied to each video asset."}]},"serviceSections":{"VideoProduction":{"id":"video-production","headline":"Production Process","subheadline":"Every video follows the same production process,|from concept to delivery.","visualVariant":"mockup","points":[{"title":"Pre-Production","description":"Strategy, scripting, storyboarding, casting, location scouting","metric":"1 week"},{"title":"Production","description":"On-location or remote filming, professional equipment, client coordination","metric":"1-2 days"},{"title":"Post-Production","description":"Editing, color grading, sound design, motion graphics, captions","metric":"1 week"},{"title":"Distribution","description":"Platform-specific formatting, delivery, performance tracking","metric":"Ongoing"}],"tableHeaders":"$undefined"},"VideoDistribution":{"id":"video-distribution","headline":"Video formats that perform.","subheadline":"Different goals require different formats.|We match the video type to the platform and the outcome.","visualVariant":"dashboard","points":[{"title":"Short-Form Social","description":"Instagram, TikTok, YT Shorts","metric":"15-30s"},{"title":"Testimonials","description":"Website, YouTube, LinkedIn","metric":"60-90s"},{"title":"Product Demos","description":"Website, YouTube, Sales","metric":"60-120s"},{"title":"Ad Creative","description":"Meta, Google, YouTube","metric":"15-30s"}],"tableHeaders":"$undefined"},"VideoStrategy":{"id":"video-strategy","headline":"The production process.","subheadline":"From concept to final delivery,|with a workflow we've refined over time.","visualVariant":"split","points":[{"title":"Strategy & Concept","description":"Define goal, audience, platform, and key message before a single frame is shot.","metric":"Creative brief delivered in 3 days"},{"title":"Scripting & Storyboard","description":"Every video starts with a script and storyboard. Iterate until the narrative arc feels right.","metric":"Script approved before production"},{"title":"Production & Filming","description":"On-location or remote with professional equipment. We handle all coordination.","metric":"Avg. 2-day shoot turnaround"}],"tableHeaders":"$undefined"}},"faq":[{"question":"Do you handle the full production process?","answer":"Yes: scripting, filming, editing, and distribution. We manage the entire workflow from concept to final delivery. You review and approve at key stages, but you don't need to manage any production logistics yourself."},{"question":"What video formats do you produce?","answer":"Short-form social content (15–30s for Reels, Shorts, and TikTok), testimonials (60–90s), product demos (60–120s), and ad creative (15–30s). We produce in all formats needed for your chosen distribution channels."},{"question":"How long does video production take?","answer":"From strategy to delivery, most projects take 3–4 weeks: 1 week for pre-production and scripting, 1–2 days for filming, and 1 week for editing and post-production. Rush timelines are possible for ad creative."},{"question":"Do you need to film on location?","answer":"For testimonials and product/service demos, on-location filming produces the best results. For social content and ad creative, we can work with footage you provide, screen recordings, or motion graphics depending on what the concept calls for."},{"question":"How do you measure video performance?","answer":"View-through rate, engagement rate (likes, shares, comments), website traffic from video, and conversion lift compared to non-video content. For ad creative, we track ROAS and CPL directly against static creative to prove video's ROI."},{"question":"How much does video production cost?","answer":"Short-form social packages start at $3,000 per project. Explainers run $5,000 to $12,000. Monthly retainers from $2,500 deliver 4 to 8 pieces. We quote on length, complexity, and number of deliverables."},{"question":"Do I need to be on camera?","answer":"Not necessarily. We produce founder-led, team interview, animation, and b-roll style depending on your brand. On camera builds trust fastest for many service businesses, but it is optional."},{"question":"Can you create video ads for Meta and Google?","answer":"Yes. We deliver ad-specific cuts in the formats and lengths each platform requires. This pairs with our Meta Ads and Google Ads management."}],"answerBlock":"Video marketing services include concept development, scripting, production coordination, editing, and distribution planning for ads, social, and web. Project pricing starts at $3,000 for short-form packages. Monthly retainers from $2,500 cover ongoing video content. Typical turnaround is 2 to 4 weeks per project.","comparison":{"title":"Video Marketing: One-Off vs. Ongoing Program","subtitle":"Compare a single video project against a monthly video content program.","layout":"stacked","columns":[{"header":"One-Off Explainer Video"},{"header":"KINEXIS Video Retainer","highlight":true}],"rows":[{"label":"Investment","values":["$$5,000 to $15,000 once","$$2,500 to $6,000/mo ongoing"]},{"label":"Content volume","values":["1 video","4 to 8 pieces per month"]},{"label":"Ad creative refresh","values":["Stale after 4 to 6 weeks","New ad cuts every month"]},{"label":"Platform coverage","values":["One format","Multi-format exports per shoot"]},{"label":"Turnaround","values":["6 to 8 weeks","2 to 4 weeks per batch"]},{"label":"Best for","values":["Website hero video","Active ad and social programs"]}]}},"breadcrumbs":[{"name":"Home","url":"/"},{"name":"Services","url":"/services"},{"name":"Video Marketing Services"}],"relatedLinks":{"services":[{"href":"/services/content-marketing","label":"Content Marketing"},{"href":"/services/social-media","label":"Social Media Marketing"},{"href":"/pricing/video-marketing","label":"Video Marketing Pricing"}],"caseStudies":[{"href":"/case-studies/landscaping-company-growth","label":"4.8X Leads · Landscaping Co."},{"href":"/case-studies/saas-platform-growth","label":"5.9X Demos · SaaS Platform"}],"blog":[],"solutions":[]}}]
