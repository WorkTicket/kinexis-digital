14:["$","$L1b",null,{"slug":"web-design","locale":"en","data":{"slug":"web-design","locale":"en","visualVariant":"mockup","visualizationSection":"WhyKinexus","hero":{"label":"Web Design Services","line1":"Websites that look good","line2":"and actually convert.","subtitle":"Built from scratch around how your buyers actually decide. Not a theme with your brand colors swapped in.","ctaLabel":"Start Your Project"},"sectionOrder":["ServiceOverview","WhyKinexus","UxAudit","DeviceMockups","ConversionOptimization","Speed","Process","Deliverables","Proof","Results","PricingTeaser"],"overview":{"headline":"Most business websites look fine and convert at 1 to 2%","problem":"A pretty site that does not generate leads is an expense. Templates and DIY builders get you online fast, but they skip the strategy that turns traffic into revenue.","solution":"Websites designed around your sales process","problemPoints":["Homepages try to say everything and guide visitors nowhere specific.","Contact forms sit at the bottom of long pages with no reason to fill them out above the fold.","Mobile experience breaks on key pages even though most traffic arrives on a phone.","Slow load times hurt ad quality and SEO while visitors bounce before the page finishes."],"solutionPoints":["Page architecture based on your services, buyer questions, and conversion goals.","Custom design that reflects your brand without sacrificing speed or usability.","Conversion elements placed where visitors actually decide: above the fold, mid-page, and at exit.","Core Web Vitals optimization so your site performs in search and paid campaigns."]},"whyKinexus":{"headline":"What Makes a Kinexus Build Different","subtitle":"Conversion paths sketched first, performance benchmarks enforced, and a handoff your marketing team can run without us.","points":[{"title":"Conversion before aesthetics","description":"We sketch the CTA path first. Pretty comes second. Awards do not pay your payroll."},{"title":"Performance is non-negotiable","description":"Lighthouse 90 or higher. Core Web Vitals green. Your site loads before people lose patience."},{"title":"Mobile-first, not mobile-adapted","description":"Wireframes start on a phone screen because that is where most of your traffic lives."},{"title":"Handoff your team can run","description":"CMS training, component docs, and a site your marketing team can update without calling us every week."}]},"proof":{"beforeAfter":{"beforeLabel":"Before","afterLabel":"After","beforeValue":"1.8%","afterValue":"8.4%","metric":"Conversion Rate"},"caseStudy":{"client":"Landscaping Company","challenge":"Template site with 45% bounce rate and no clear CTA above the fold.","outcome":"4.8× lead growth after custom rebuild. Conversion rate went from 1.8% to 8.4% with Lighthouse 94 score.","href":"/case-studies/landscaping-company-growth"}},"results":{"title":"Results we track","subtitle":"Measurable outcomes from recent web projects.","metrics":[{"metric":"1.8% → 8.4%","label":"conversion rate · Landscaping Co. rebuild"},{"metric":"4.8X","label":"qualified lead growth · same client, 10 mo"},{"metric":"Lighthouse 94","label":"performance score · post-launch"}]},"process":{"title":"The build process.","subtitle":"From discovery to launch,|every phase has a clear deliverable and a defined success metric.","steps":[{"title":"Discovery & Strategy","desc":"User behavior analysis, competitor audit, stakeholder interviews. Output: strategic brief and sitemap.","metric":"Strategic brief delivered in week 1"},{"title":"UX & Wireframing","desc":"High-fidelity wireframes mapping every user journey. Navigation flows tested before a single pixel is designed.","metric":"Every user journey mapped before design"},{"title":"Visual Design","desc":"Full-color mockups rooted in conversion psychology. Each block has a clear hierarchy and purpose.","metric":"Conversion-focused mockups in 2 weeks"},{"title":"Development & QA","desc":"Clean code, Lighthouse 90+, WCAG accessible. Cross-browser tested on every device.","metric":"Lighthouse 90+ on every build"},{"title":"Launch & Handoff","desc":"Zero-downtime deployment, DNS migration, CMS training. Your team can hit the ground running.","metric":"Zero-downtime deployment guaranteed"}]},"deliverables":{"title":"Web design project deliverables","subtitle":"Discovery through go-live. Every deliverable serves the same goal: qualified visitors who take action.","items":[{"title":"Discovery and UX Strategy","description":"Buyer research, sitemap, wireframes, and conversion path mapping before any design work starts."},{"title":"Custom Visual Design","description":"Brand-aligned mockups for key pages with mobile and desktop layouts, no templates."},{"title":"Responsive Development","description":"Clean, fast code on modern frameworks with CMS integration for easy content updates."},{"title":"Conversion-Focused Page Templates","description":"Service pages, landing pages, and contact flows built with forms, CTAs, and trust signals."},{"title":"On-Page SEO Foundation","description":"Title tags, meta descriptions, schema markup, and site structure ready for organic growth."},{"title":"Launch Support and Training","description":"QA testing, analytics setup, CMS training, and 30 days of post-launch adjustments."}]},"serviceSections":{"UxAudit":{"id":"ux-audit","headline":"Before & After","subheadline":"Real before-and-after results from real projects.|Every number represents a measurable business outcome.","visualVariant":"comparison","points":[{"title":"+425% conversion lift","description":"Generic template-based layout","metric":"Custom brand experience from scratch"},{"title":"3.8x mobile engagement","description":"Desktop-only design mentality","metric":"Mobile-first architecture from wireframes"}],"tableHeaders":"$undefined"},"DeviceMockups":{"id":"device-mockups","headline":"Every surface matters.","subheadline":"Your website lives across devices, viewports, and contexts.|We design and test every experience to ensure consistency at every size.","visualVariant":"mockup","points":[{"title":"Desktop","description":"Responsive across breakpoints"},{"title":"Tablet","description":"Responsive across breakpoints"},{"title":"Mobile","description":"Responsive across breakpoints"}],"tableHeaders":"$undefined"},"ConversionOptimization":{"id":"conversion-optimization","headline":"Conversion Optimization","subheadline":"Layout choices tied to one goal.","visualVariant":"comparison","points":[{"title":"Above-fold CTA","description":"Primary action without scroll","metric":"+425%"},{"title":"Trust signals","description":"Logos and testimonials first","metric":"3.8x"}],"tableHeaders":"$undefined"},"Speed":{"id":"speed","headline":"Built for performance.","subheadline":"A beautiful site that loads slowly is a broken site.|We obsess over every byte, every request, and every render.","visualVariant":"chart","points":[{"title":"Load Time","description":"P75 across all projects","metric":"Pass"},{"title":"Lighthouse Score","description":"Mobile + Desktop average","metric":"Pass"},{"title":"Core Web Vitals","description":"LCP, INP, CLS all green","metric":"Pass"},{"title":"Accessibility","description":"WCAG 2.1 compliant","metric":"Pass"}],"tableHeaders":"$undefined"}},"faq":[{"question":"How long does a website project take?","answer":"Most projects run 6–10 weeks: 1 week discovery, 1–2 weeks UX and wireframing, 2–3 weeks visual design, 2–3 weeks development and QA, then launch. Complex sites with e-commerce or custom functionality may take longer."},{"question":"Do you build on specific platforms or CMS?","answer":"We build custom sites and work with WordPress and Webflow depending on your team's needs and the complexity of the project. We recommend the right stack for your goals, not the one that's easiest for us."},{"question":"Will my site be fast and mobile-optimized?","answer":"Yes. Every site we build hits Lighthouse 90+ on mobile and desktop, passes Core Web Vitals, and meets WCAG 2.1 accessibility standards. Performance is baked into the build process, not bolted on at the end."},{"question":"Do you handle content migration from my existing site?","answer":"Yes. If you have existing content worth keeping, we migrate and restructure it as part of the build. We'll audit your current content and recommend what to keep, update, or retire."},{"question":"Can you redesign an existing website?","answer":"Yes. Redesigns are a common engagement. We audit your current site, identify what's working and what isn't, and rebuild it with a clear conversion strategy and modern performance standards."},{"question":"How much does a custom website cost?","answer":"Most business websites range from $8,000 to $35,000 depending on page count, custom functionality, and integrations. E-commerce and multi-location sites may exceed that range. We provide a fixed quote after discovery."},{"question":"How long does a web design project take?","answer":"Standard business websites take 6 to 10 weeks from kickoff to launch. Larger sites with custom features may take 10 to 14 weeks. We set a clear timeline in your proposal with milestone check-ins."},{"question":"Do you redesign existing websites or only build new ones?","answer":"Both. We redesign underperforming sites and build new ones from scratch. Redesigns often include a conversion audit first so we fix what is broken before changing the design."},{"question":"What CMS do you build on?","answer":"We primarily build on Next.js and headless CMS platforms for speed and flexibility. For clients who need WordPress, we build custom themes without page builder bloat."}],"answerBlock":"Web design includes discovery, UX strategy, custom design, responsive development, CMS setup, basic SEO structure, and conversion-focused layouts. Projects run $8,000 for focused sites to $35,000+ for larger builds. Typical delivery is 6 to 10 weeks from kickoff to launch.","comparison":{"title":"Custom Web Design vs. Template Builders","subtitle":"Compare a conversion-focused custom build against DIY and template options.","layout":"contrast","columns":[{"header":"Template / DIY Builder"},{"header":"KINEXIS Web Design","highlight":true}],"rows":[{"label":"Strategy and UX","values":["Pick a theme, add text","Discovery, wireframes, and conversion mapping"]},{"label":"Page speed","values":["Bloated themes, slow loads","Optimized for Core Web Vitals"]},{"label":"Conversion design","values":["Generic layouts","CTAs and forms placed by intent"]},{"label":"SEO readiness","values":["Basic, plugin-dependent","Built-in structure and schema"]},{"label":"Project cost","values":["$$500 to $3,000","$$8,000 to $35,000"]},{"label":"Typical conversion lift","values":["Baseline","25 to 60% increase with paired CRO"]}]}},"breadcrumbs":[{"name":"Home","url":"/"},{"name":"Services","url":"/services"},{"name":"Web Design Services"}],"relatedLinks":{"services":[{"href":"/services/funnels","label":"Funnels & Conversion Rate Optimization"},{"href":"/services/seo","label":"SEO Services"},{"href":"/pricing/web-design","label":"Web Design Pricing"}],"caseStudies":[{"href":"/case-studies/landscaping-company-growth","label":"4.8X Leads · Landscaping Co."},{"href":"/case-studies/saas-platform-growth","label":"5.9X Demos · SaaS Platform"}],"blog":[{"href":"/blog/website-conversion-optimization","label":"Website Conversion Optimization"},{"href":"/blog/landing-page-optimization","label":"Landing Page Optimization"}],"solutions":[]}}]
