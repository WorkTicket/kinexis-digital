11:Tb43,{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"How long does a website project take?","acceptedAnswer":{"@type":"Answer","text":"Most projects run 6–10 weeks: 1 week discovery, 1–2 weeks UX and wireframing, 2–3 weeks visual design, 2–3 weeks development and QA, then launch. Complex sites with e-commerce or custom functionality may take longer."}},{"@type":"Question","name":"Do you build on specific platforms or CMS?","acceptedAnswer":{"@type":"Answer","text":"We build custom sites and work with WordPress and Webflow depending on your team's needs and the complexity of the project. We recommend the right stack for your goals, not the one that's easiest for us."}},{"@type":"Question","name":"Will my site be fast and mobile-optimized?","acceptedAnswer":{"@type":"Answer","text":"Yes. Every site we build hits Lighthouse 90+ on mobile and desktop, passes Core Web Vitals, and meets WCAG 2.1 accessibility standards. Performance is baked into the build process, not bolted on at the end."}},{"@type":"Question","name":"Do you handle content migration from my existing site?","acceptedAnswer":{"@type":"Answer","text":"Yes. If you have existing content worth keeping, we migrate and restructure it as part of the build. We'll audit your current content and recommend what to keep, update, or retire."}},{"@type":"Question","name":"Can you redesign an existing website?","acceptedAnswer":{"@type":"Answer","text":"Yes. Redesigns are a common engagement. We audit your current site, identify what's working and what isn't, and rebuild it with a clear conversion strategy and modern performance standards."}},{"@type":"Question","name":"How much does a custom website cost?","acceptedAnswer":{"@type":"Answer","text":"Most business websites range from $8,000 to $35,000 depending on page count, custom functionality, and integrations. E-commerce and multi-location sites may exceed that range. We provide a fixed quote after discovery."}},{"@type":"Question","name":"How long does a web design project take?","acceptedAnswer":{"@type":"Answer","text":"Standard business websites take 6 to 10 weeks from kickoff to launch. Larger sites with custom features may take 10 to 14 weeks. We set a clear timeline in your proposal with milestone check-ins."}},{"@type":"Question","name":"Do you redesign existing websites or only build new ones?","acceptedAnswer":{"@type":"Answer","text":"Both. We redesign underperforming sites and build new ones from scratch. Redesigns often include a conversion audit first so we fix what is broken before changing the design."}},{"@type":"Question","name":"What CMS do you build on?","acceptedAnswer":{"@type":"Answer","text":"We primarily build on Next.js and headless CMS platforms for speed and flexibility. For clients who need WordPress, we build custom themes without page builder bloat."}}]}6:[[["$","script","0",{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Organization\",\"@id\":\"https://www.kinexisdigital.com/#organization\",\"name\":\"KINEXIS Digital\",\"url\":\"https://www.kinexisdigital.com\",\"logo\":{\"@type\":\"ImageObject\",\"url\":\"https://www.kinexisdigital.com/assets/logos/KINEXIS_icon_logo.webp\",\"width\":512,\"height\":512},\"description\":\"Digital marketing agency specializing in SEO, paid media, web design, CRO, and analytics for local businesses, SaaS companies, and enterprise organizations.\",\"sameAs\":[\"https://www.linkedin.com/company/kinexisdigital\"],\"contactPoint\":{\"@type\":\"ContactPoint\",\"contactType\":\"sales\",\"email\":\"hello@kinexisdigital.com\",\"availableLanguage\":[\"English\",\"Spanish\"]}}"}}],["$","script","1",{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Service\",\"@id\":\"https://www.kinexisdigital.com/en/services/web-design#service\",\"name\":\"Web Design Services\",\"description\":\"Custom web design built to convert visitors into leads. Strategy, UX, development, and CRO included. Projects from $8,000 to $35,000, delivered in 6 to 10…\",\"provider\":{\"@id\":\"https://www.kinexisdigital.com/#organization\"},\"url\":\"https://www.kinexisdigital.com/en/services/web-design\",\"areaServed\":{\"@type\":\"Country\",\"name\":\"Worldwide\"}}"}}],["$","script","2",{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$11"}}],"$L12"],"$L13","$L14"]
