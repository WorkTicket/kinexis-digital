11:Td62,{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Which social platforms do you manage?","acceptedAnswer":{"@type":"Answer","text":"We focus on LinkedIn, Instagram, and X (Twitter). We recommend the platforms where your specific audience is most active and where your content type will perform best, not every platform for the sake of presence."}},{"@type":"Question","name":"How many posts do you create per month?","acceptedAnswer":{"@type":"Answer","text":"Our clients receive 20+ assets per month including posts, stories, carousels, and short-form video. Every asset is created from scratch for your brand, with no recycled templates or generic stock photo captions."}},{"@type":"Question","name":"Do you respond to comments and messages?","acceptedAnswer":{"@type":"Answer","text":"Yes. Community management is included in every social media plan. We monitor and respond to comments, mentions, and DMs daily to maintain an active presence and build real relationships with your audience."}},{"@type":"Question","name":"How do you measure social media results?","acceptedAnswer":{"@type":"Answer","text":"Follower growth rate, engagement rate, reach, website traffic from social, and leads attributed to social channels. We track these monthly and adjust content strategy based on what's actually driving performance."}},{"@type":"Question","name":"Can social media generate direct leads for my business?","acceptedAnswer":{"@type":"Answer","text":"Yes, especially LinkedIn for B2B. We combine organic content with lead magnet promotion and DM outreach sequences to generate qualified pipeline directly from social. Instagram and X also drive leads for the right service businesses."}},{"@type":"Question","name":"How much does social media management cost?","acceptedAnswer":{"@type":"Answer","text":"Management starts at $1,500 per month for two platforms with twelve posts and monthly reporting. Growth plans at $3,000 per month cover three to four platforms with paid amplification and community engagement. Scale is $5,500+ for multi-platform programs with video production and advanced analytics. Paid boost and campaign ad spend is separate from management fees."}},{"@type":"Question","name":"Which social media platforms do you manage?","acceptedAnswer":{"@type":"Answer","text":"LinkedIn, Instagram, Facebook, and X. We usually recommend 2 to 3 platforms where your buyers are active instead of spreading thin everywhere."}},{"@type":"Question","name":"How is social media management different from Meta Ads?","acceptedAnswer":{"@type":"Answer","text":"Social management is organic content, posting, and community work. Meta Ads is paid Facebook and Instagram advertising. They work well together but play different roles."}},{"@type":"Question","name":"Do you create graphics and videos for social posts?","acceptedAnswer":{"@type":"Answer","text":"Yes. Graphics, carousels, and short video clips are included in management packages. Long-form video production goes through our video marketing service."}},{"@type":"Question","name":"Can social media actually generate leads for B2B?","acceptedAnswer":{"@type":"Answer","text":"Social is rarely a standalone lead channel for B2B, but it builds trust, warms prospects, and sends qualified traffic to your content, offers, and site. We track click-throughs and attribute leads that started from social touchpoints."}}]}6:[[["$","script","0",{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Organization\",\"@id\":\"https://www.kinexisdigital.com/#organization\",\"name\":\"KINEXIS Digital\",\"url\":\"https://www.kinexisdigital.com\",\"logo\":{\"@type\":\"ImageObject\",\"url\":\"https://www.kinexisdigital.com/assets/logos/KINEXIS_icon_logo.webp\",\"width\":512,\"height\":512},\"description\":\"Digital marketing agency specializing in SEO, paid media, web design, CRO, and analytics for local businesses, SaaS companies, and enterprise organizations.\",\"sameAs\":[\"https://www.linkedin.com/company/kinexisdigital\"],\"contactPoint\":{\"@type\":\"ContactPoint\",\"contactType\":\"sales\",\"email\":\"hello@kinexisdigital.com\",\"availableLanguage\":[\"English\",\"Spanish\"]}}"}}],["$","script","1",{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Service\",\"@id\":\"https://www.kinexisdigital.com/en/services/social-media#service\",\"name\":\"Social Media Marketing Services\",\"description\":\"Social media management that builds brand visibility and drives qualified traffic to your website. Content creation, scheduling, and community engagement…\",\"provider\":{\"@id\":\"https://www.kinexisdigital.com/#organization\"},\"url\":\"https://www.kinexisdigital.com/en/services/social-media\",\"areaServed\":{\"@type\":\"Country\",\"name\":\"Worldwide\"}}"}}],["$","script","2",{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$11"}}],"$L12"],"$L13","$L14"]
