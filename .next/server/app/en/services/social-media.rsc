ty":"high","children":[["$","span",null,{"className":"type-hero-line hero-intentional-hero-line","children":"Social that supports"}],["$","span",null,{"className":"type-hero-line hero-intentional-hero-line","children":"the rest of your marketing."}]]}],["$","p",null,{"className":"hero__subtitle","fetchPriority":"high","children":["$","span",null,{"className":"type-body-line hero-intentional-subtitle-line","children":"Consistent, on-brand presence that keeps you visible to buyers who haven't decided yet and sends them somewhere useful when they are."}]}],["$","div",null,{"className":"hero__cta cta-stack","children":["$L19","$L1a"]}]]}]}]}]]}]
14:["$","$L1b",null,{"slug":"social-media","locale":"en","data":{"slug":"social-media","locale":"en","visualVariant":"dashboard","visualizationSection":"WhyKinexus","hero":{"label":"Social Media Marketing","line1":"Social that supports","line2":"the rest of your marketing.","subtitle":"Consistent, on-brand presence that keeps you visible to buyers who haven't decided yet and sends them somewhere useful when they are.","ctaLabel":"Start Your Social Strategy"},"sectionOrder":["Results","ServiceOverview","WhyKinexus","PlatformStrategy","ContentPillars","Community","Process","Deliverables","Proof","PricingTeaser"],"overview":{"headline":"An inactive profile hurts trust faster than no profile at all","problem":"Posting when someone remembers, with no clear voice or goal, makes you look smaller than you are. Social only helps when it connects to traffic, offers, and leads.","solution":"Social tied to revenue goals, not vanity metrics","problemPoints":["Promotional posts go out sporadically and get ignored.","No content pillars or voice guidelines, so every post feels like a different company.","Likes and follows get tracked while website clicks and leads do not.","Comments and DMs sit unanswered for days, which signals you are not paying attention."],"solutionPoints":["Platform focus on where your buyers actually spend time, not every network at once.","Content pillars aligned with your services, expertise, and the questions buyers ask.","Steady posting with graphics, captions, and hashtags tuned per platform.","Community replies on comments and DMs within 24 hours."]},"whyKinexus":{"headline":"The Kinexus Social Growth Framework","subtitle":"Platform fit over checklist presence, content pillars with ROI, and social wired into retargeting and pipeline.","points":[{"title":"Platform fit over presence","description":"We pick the two networks where your buyers actually show up. Not all six because a checklist said to."},{"title":"Content pillars with ROI","description":"Every post category maps to a funnel stage and a number we can report on."},{"title":"Paid + organic integration","description":"Organic posts feed retargeting pools and ad creative tests. Social is not a standalone island."},{"title":"Community as pipeline","description":"Comments and DMs trigger sales follow-up. Likes alone do not pay rent."}]},"proof":{"caseStudy":{"client":"SaaS Platform","challenge":"LinkedIn posts went out twice a month with no content pillars. Follower count grew but website clicks and demo pipeline stayed flat because nothing connected social to offers.","outcome":"2.1x inbound leads from social traffic after content pillar strategy aligned posts to SEO topics and every post included a clear path to demo booking.","href":"/case-studies/saas-platform-growth"}},"results":{"title":"Results we track","subtitle":"Social media outcomes from recent client programs.","metrics":[{"metric":"+15%/mo","label":"organic follower growth · B2B brand"},{"metric":"3.8%","label":"avg. engagement rate · above industry avg."},{"metric":"+25%","label":"leads attributed from social traffic"}]},"process":{"title":"The social process.","subtitle":"From audit to ongoing management:|a step-by-step approach to building audience and engagement.","steps":[{"title":"Audit & Platform Strategy","desc":"Analyze current presence. Pick the right platforms, not every platform.","metric":"Platform strategy delivered in week 1"},{"title":"Content Calendar & Guidelines","desc":"Monthly calendar tied to goals. Visual and tone guidelines keep everything consistent.","metric":"30-day content calendar per month"},{"title":"Production & Scheduling","desc":"Custom graphics, short-form video, carousels, all scheduled in advance.","metric":"20+ assets produced per month"},{"title":"Community Management","desc":"Daily engagement with comments, mentions, DMs. Real conversations, not bots.","metric":"Avg. 4.2% engagement rate"},{"title":"Reporting & Optimization","desc":"Monthly reports on reach, engagement, growth, and lead attribution.","metric":"18% month-over-month audience growth"}]},"deliverables":{"title":"What you get with social media management","subtitle":"Content, scheduling, community management, and traffic CTAs. All managed.","items":[{"title":"Platform Strategy and Content Pillars","description":"Channel selection, posting frequency, content themes, and brand voice guidelines."},{"title":"Content Creation and Design","description":"Graphics, carousels, short-form copy, and video snippets tailored to each platform."},{"title":"Scheduling and Publishing","description":"Consistent posting calendar with optimal send times and platform-specific formatting."},{"title":"Community Management","description":"Comment responses, DM handling, and engagement with relevant accounts in your space."},{"title":"Social-to-Website CTAs","description":"Bio links, story CTAs, and post copy that drive traffic to landing pages and offers."},{"title":"Monthly Analytics Report","description":"Follower growth, reach, engagement, click-throughs, and top-performing content breakdown."}]},"serviceSections":{"PlatformStrategy":{"id":"platform-strategy","headline":"Platform Performance Matrix","subheadline":"Each platform requires a different content approach,|cadence, and engagement strategy.","visualVariant":"dashboard","points":[{"title":"LinkedIn","description":"Long-form posts, carousels, articles","metric":"4.2%"},{"title":"Instagram","description":"Reels, stories, carousels","metric":"3.8%"},{"title":"Facebook","description":"Posts, reels, community updates","metric":"2.4%"},{"title":"X (Twitter)","description":"Threads, hot takes, engagement","metric":"2.1%"}],"tableHeaders":"$undefined"},"ContentPillars":{"id":"content-pillars","headline":"Content pillar system.","subheadline":"Every post fits into one of four content pillars,|ensuring variety without losing brand consistency.","visualVariant":"split","points":[{"title":"Thought Leadership","description":"Industry insights, predictions, original research","metric":"Builds authority"},{"title":"Social Proof","description":"Client results, testimonials, case studies","metric":"Drives trust"},{"title":"Educational","description":"How-tos, tips, frameworks, templates","metric":"Generates leads"},{"title":"Cultural","description":"Behind-the-scenes, team, values","metric":"Humanizes brand"}],"tableHeaders":"$undefined"},"Community":{"id":"community","headline":"Performance metrics.","subheadline":"Real results from organic social strategies,|measured, reported, and optimized.","visualVariant":"comparison","points":[{"title":"Monthly Follower Growth","description":"Organic, no paid promotion","metric":"15%"},{"title":"Engagement Rate","description":"Across all platforms","metric":"3.8%"},{"title":"Leads Attributed","description":"From social channels","metric":"25%"},{"title":"Reach Growth","description":"Month-over-month audience","metric":"18%"}],"tableHeaders":"$undefined"}},"faq":[{"question":"Which social platforms do you manage?","answer":"We focus on LinkedIn, Instagram, and X (Twitter). We recommend the platforms where your specific audience is most active and where your content type will perform best, not every platform for the sake of presence."},{"question":"How many posts do you create per month?","answer":"Our clients receive 20+ assets per month including posts, stories, carousels, and short-form video. Every asset is created from scratch for your brand, with no recycled templates or generic stock photo captions."},{"question":"Do you respond to comments and messages?","answer":"Yes. Community management is included in every social media plan. We monitor and respond to comments, mentions, and DMs daily to maintain an active presence and build real relationships with your audience."},{"question":"How do you measure social media results?","answer":"Follower growth rate, engagement rate, reach, website traffic from social, and leads attributed to social channels. We track these monthly and adjust content strategy based on what's actually driving performance."},{"question":"Can social media generate direct leads for my business?","answer":"Yes, especially LinkedIn for B2B. We combine organic content with lead magnet promotion and DM outreach sequences to generate qualified pipeline directly from social. Instagram and X also drive leads for the right service businesses."},{"question":"How much does social media management cost?","answer":"Management starts at $1,500 per month for two platforms with twelve posts and monthly reporting. Growth plans at $3,000 per month cover three to four platforms with paid amplification and community engagement. Scale is $5,500+ for multi-platform programs with video production and advanced analytics. Paid boost and campaign ad spend is separate from management fees."},{"question":"Which social media platforms do you manage?","answer":"LinkedIn, Instagram, Facebook, and X. We usually recommend 2 to 3 platforms where your buyers are active instead of spreading thin everywhere."},{"question":"How is social media management different from Meta Ads?","answer":"Social management is organic content, posting, and community work. Meta Ads is paid Facebook and Instagram advertising. They work well together but play different roles."},{"question":"Do you create graphics and videos for social posts?","answer":"Yes. Graphics, carousels, and short video clips are included in management packages. Long-form video production goes through our video marketing service."},{"question":"Can social media actually generate leads for B2B?","answer":"Social is rarely a standalone lead channel for B2B, but it builds trust, warms prospects, and sends qualified traffic to your content, offers, and site. We track click-throughs and attribute leads that started from social touchpoints."}],"answerBlock":"Social media marketing includes platform strategy, content creation, posting schedules, community management, and performance reporting for LinkedIn, Instagram, Facebook, and X. Management starts at $1,500 to $4,000 per month depending on platforms and posting frequency. Content calendars are live within 2 weeks of kickoff.","comparison":{"title":"Social Media: In-House vs. Managed","subtitle":"Compare hiring internally against a managed social media program.","layout":"ledger","columns":[{"header":"In-House Social Manager"},{"header":"KINEXIS Social Media","highlight":true}],"rows":[{"label":"Monthly cost","values":["$$4,000 to $6,000 salary plus tools","$$1,500 to $4,000 all-in"]},{"label":"Content volume","values":["Limited by one person","Design, copy, and scheduling team"]},{"label":"Platform coverage","values":["1 to 2 platforms well","Multi-platform with platform-specific content"]},{"label":"Strategy","values":["Often reactive posting","Content pillars tied to business goals"]},{"label":"Community management","values":["Business hours only","Daily monitoring and response"]},{"label":"Time to launch","values":["30 to 60 days to hire","2 weeks to live content calendar"]}]}},"breadcrumbs":[{"name":"Home","url":"/"},{"name":"Services","url":"/services"},{"name":"Social Media Marketing Services"}],"relatedLinks":{"services":[{"href":"/services/meta-ads","label":"Meta Ads Management"},{"href":"/services/content-marketing","label":"Content Marketing"},{"href":"/pricing/social-media","label":"Social Media Marketing Pricing"}],"caseStudies":[{"href":"/case-studies/landscaping-company-growth","label":"4.8X Leads · Landscaping Co."},{"href":"/case-studies/saas-platform-growth","label":"5.9X Demos · SaaS Platform"}],"blog":[{"href":"/blog/local-business-growth-playbook","label":"Local Business Growth Playbook"}],"solutions":[]}}]
