15:["$","$L16","en",{"formats":"$undefined","locale":"en","messages":{"metadata":{"title":"KINEXIS Digital - Turn Traffic Into Revenue","description":"We're a digital marketing agency that builds real sales systems, not fancy brochures. We specialize in SEO, paid ads, web design, and conversion funnels - all designed to get your phone ringing with qualified leads.","ogDescription":"We build real sales systems for businesses that want predictable growth - not just pretty websites."},"nav":{"home":"Home","agency":"Agency","services":"Services","industries":"Industries","caseStudies":"Case Studies","about":"About","blog":"Blog","pricing":"Pricing","resources":"Resources","contact":"Contact","toggleMenu":"Toggle menu","closeMenu":"Close menu","menu":"Menu","servicesOverview":"Services Overview","viewAllServices":"View All Services","industriesOverview":"Industries Overview","viewAllIndustries":"View All Industries","resourcesOverview":"Resources Hub","viewAllResources":"View All Resources","explore":"Explore","serviceGroups":{"searchAndAds":"Search & Paid Media","webAndConversion":"Website & Conversion","brandAndContent":"Brand & Content"},"resourceLinks":{"groups":{"guides":"KINEXIS Guides","comparisons":"Comparisons"},"localSeoChecklist":"Local SEO Checklist","seoAuditFramework":"SEO Audit Framework","landingPageBestPractices":"Landing Page Best Practices","abTestingFramework":"A/B Testing Framework","googleAdsVsSeo":"Google Ads vs SEO","seoVsPpc":"SEO vs PPC","localSeoVsGoogleAds":"Local SEO vs Google Ads","wordpressVsWebflow":"WordPress vs Webflow","toolkitTitle":"Marketing Toolkit","toolkitDesc":"17 tools we use daily, grouped by channel."},"bookCall":"Book a Strategy Call","bookCallShort":"Book Call"},"services":{"webDesign":"Website Design","seo":"SEO","localSeo":"Local SEO","paidAds":"Paid Ads","ppcManagement":"PPC Management","googleAds":"Google Ads Management","metaAds":"Meta Ads Management","funnels":"Funnels & Conversion Rate Optimization","branding":"Branding","contentMarketing":"Content Marketing","emailMarketing":"Email Marketing & Automation","socialMedia":"Social Media Management","videoMarketing":"Video Marketing","analytics":"Analytics & Reporting","cro":"Conversion Rate Optimization","growthConsulting":"Growth Strategy & Consulting","content":"Content","webDesignShort":"Web Design","funnelsShort":"Funnels & CRO"},"footer":{"tagline":"We turn inconsistent traffic into predictable revenue systems.","navigation":"Navigation","services":"Services","contact":"Contact","copyright":"KINEXIS Digital. All rights reserved.","builtWith":"Built with strategy, not templates.","missionTitle":"We take on 8–10 clients at a time.","missionBody":"Focused engagements. Real results. No cookie-cutter playbooks.","privacy":"Privacy Policy","terms":"Terms of Service"},"common":{"bookStrategyCall":"Book a Strategy Call","scheduleStrategyCall":"Schedule a Strategy Call","learnAboutUs":"Learn About Us","viewAllServices":"View All Services","viewCaseStudy":"View Case Study","viewAllCaseStudies":"View All Case Studies","outcomeComparison":"Outcome comparison","getFreeAudit":"Get Free Audit","requestProposal":"Request Proposal","atAGlance":"At a Glance"},"language":{"label":"Language","en":"English","es":"Español (LATAM)"},"hero":{"line1":"WE DON'T","line2":"GENERATE LEADS.","line3":"WE BUILD","line3Highlight":"MARKET DOMINANCE.","subtitle":"We build the marketing infrastructure that turns qualified traffic into predictable revenue.|SEO, paid media, web design, and conversion systems that work together, not in silos."},"revenueEngine":{"label":"The KINEXIS Framework","title":"Visibility → Traffic → Leads → Revenue","subtitle":"A clear path from visibility to revenue. Each stage builds on the last.","liveTrajectory":"Live trajectory","stage":"Stage","trajectoryPeriod":"7-month trajectory","metricStart":"Start","metricCurrent":"Current","chartStart":"Start","chartEnd":"Now","stages":{"visibility":{"label":"Visibility","description":"Qualified visitors from search, social, and paid channels","tags":["SEO","Paid Ads","Social"]},"traffic":{"label":"Traffic","description":"Pages built to convert, wherever people find you","tags":["Landing Pages","Lead Magnets"]},"leads":{"label":"Leads","description":"Frictionless capture and strategic sales conversations","tags":["Forms","Discovery Calls"]},"revenue":{"label":"Revenue","description":"Predictable growth in recurring revenue and lifetime value","tags":["MRR","LTV"]}},"chartUnits":{"visibility":"impressions (K)","traffic":"sessions (K)","leads":"leads/mo","revenue":"$$K MRR"}},"servicesEcosystem":{"label":"Connected Services","title":"Services that work together.","subtitle":"SEO feeds content. Content feeds funnels. Funnels feed email.|Each channel makes the next one work harder."},"featuredResults":{"label":"Proven Results","title":"Outcomes, not opinions.","subtitle":"Real trajectories from real client work.|This is how we measure success.","cases":{"landscaping":{"category":"Home Services","title":"Landscaping Company","headline":"5X Revenue Growth","summary":"A complete website rebuild and local SEO campaign turned this business around. Revenue went from $2,000/mo to $11,500/mo in 8 months."},"dental":{"category":"Healthcare","title":"Dental Practice","headline":"340% More Patients","summary":"Multi-location dental practice. Local SEO overhaul and ad restructure drove new patient bookings from 45 to 198 per month."},"ecommerce":{"category":"Retail","title":"Premium E-Commerce Brand","headline":"4X Monthly Revenue","summary":"Brand repositioning and site rebuild lifted AOV from $85 to $238 and revenue from $12K to $45K per month."}}},"philosophy":{"label":"Why Clients Switch To KINEXIS","title":"You've been here before.","subtitle":"Another agency. Another promise.|Another dashboard full of numbers that don't connect to revenue.","before":"Before","after":"After","agencyA":"Agency A","beforeItems":["Slow communication","No reporting","No transparency","Vanity metrics","Rotating account managers"],"afterItems":["Weekly reporting","Clear KPIs","Dedicated strategist","Revenue-focused metrics","Direct access to leadership"],"statusBefore":"Disconnected","statusAfter":"Revenue-aligned","dashboardBefore":"Q4 dashboard","dashboardAfter":"Live KPI board","pipelineLabel":"Pipeline value","pipelineBefore":"↓ 22%","pipelineAfter":"↑ 3.2×","statImpressions":"Impressions","statEngagement":"Engagement","statRevenue":"Revenue","beforeItemDetails":["Three-day email loops and vague updates. Urgent issues wait until your next scheduled call while ad spend keeps burning.","A PDF once a quarter, if you're lucky. No visibility into what's working, what's wasted, or what changed last week.","Black-box billing and unclear scope. You never know who's doing the work or where your budget actually goes.","They celebrate impressions and clicks while your pipeline stays flat. Activity looks busy. Revenue does not move.","Every quarter someone new owns your account. Context resets and you're re-explaining your business from scratch."],"afterItemDetails":["Every Monday: spend, leads, CPL, and pipeline in one digest. You always know where you stand and what's being optimized.","We agree on targets upfront: revenue, cost per lead, conversion rate. We report against them every week.","One senior strategist owns your account end-to-end. They know your business, market, and numbers. No handoffs.","We track what hits your P&L: qualified leads, close rate, ROAS, and LTV. Vanity metrics are context, never the headline.","Skip the ticket queue. When something matters, you're talking to decision-makers who can change direction fast."]},"cta":{"label":"Let's Talk","title":"Ready to Build a","titleHighlight":"Revenue System?","subtitle":"No rehearsed pitch. No pressure to sign anything.|Just a straightforward conversation about what real growth could look like for your business."},"midCta":{"label":"Next Step","title":"See what's possible|for your business","subtitle":"Book a strategy call or request a free audit.|We'll show you where your growth engine is leaking and how to fix it.","secondaryCta":"Get Free Audit"},"chatbot":{"openChat":"Open chat","closeChat":"Close chat","chatMessage":"Chat message","sendMessage":"Send message","assistantName":"KINEXIS AI","assistantRole":"Sales assistant","placeholder":"Type your answer...","initialMessage":"Quick question: are you looking for SEO, paid ads, web design, or something else?","questions":{"service":"What service are you looking for? (SEO, Paid Ads, Web Design, Funnels, Branding)","business":"What type of business do you run?","revenue":"What's your monthly revenue range?","goal":"What's your primary goal? (leads, sales, brand growth)"},"quickReplies":{"services":["SEO","Paid Ads","Web Design","Funnels","Branding"],"businessTypes":["E-Commerce","Local Service","SaaS","Professional Services"],"revenue":["Under $10k/mo","$$10k-$50k/mo","$$50k-$100k/mo","$$100k+/mo"],"goals":["More leads","More sales","Brand awareness","All of the above"]},"highIntentResponse":"You sound like a great fit! Let's get you booked for a strategy call. 👇","lowIntentResponse":"Thanks! Start with our free growth audit. It'll give you a clear picture of where to focus. 👇"},"cookies":{"title":"We use cookies","description":"We use essential cookies to run this site and, with your consent, analytics cookies to understand how visitors use kinexisdigital.com. See our","privacyLink":"Privacy Policy","accept":"Accept analytics","reject":"Reject non-essential"}},"now":"$undefined","timeZone":"America/Bogota","children":"$L17"}]
