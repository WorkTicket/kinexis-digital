11:T5c1,{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Are you a local marketing agency or a growth agency?","acceptedAnswer":{"@type":"Answer","text":"Both. We serve local service businesses with geo-targeted SEO and ads, and we serve SaaS, startup, and enterprise clients with full-funnel programs. Our team is structured to handle both without applying the wrong playbook."}},{"@type":"Question","name":"What makes KINEXIS different from other digital marketing agencies?","acceptedAnswer":{"@type":"Answer","text":"We sell integrated revenue systems, not disconnected tactics. Every channel connects to the next, every recommendation ties to a business outcome, and we keep our client roster intentionally small."}},{"@type":"Question","name":"Do you require long-term contracts?","acceptedAnswer":{"@type":"Answer","text":"We prefer month-to-month engagements. Results earn retention, not contract lock-in."}},{"@type":"Question","name":"How do you measure success?","acceptedAnswer":{"@type":"Answer","text":"Revenue, cost per lead, conversion rates, pipeline value, ROAS, and MRR depending on your business model. We report vanity metrics but never optimize for them."}},{"@type":"Question","name":"Can you manage our entire marketing stack?","acceptedAnswer":{"@type":"Answer","text":"Yes. Most clients engage us for multiple services (SEO, paid media, web, email, and analytics) managed as one coordinated growth program."}}]}6:[[["$","script","0",{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Organization\",\"name\":\"KINEXIS Digital\",\"url\":\"https://www.kinexisdigital.com\",\"logo\":\"https://www.kinexisdigital.com/logo.png\",\"description\":\"Digital marketing agency specializing in SEO, paid media, web design, CRO, and analytics for local businesses, SaaS companies, and enterprise organizations.\",\"sameAs\":[\"https://www.linkedin.com/company/kinexisdigital\"],\"contactPoint\":{\"@type\":\"ContactPoint\",\"contactType\":\"sales\",\"availableLanguage\":[\"English\",\"Spanish\",\"French\",\"German\"]}}"}}],["$","script","1",{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"LocalBusiness\",\"name\":\"KINEXIS Digital\",\"url\":\"https://www.kinexisdigital.com\",\"description\":\"Digital marketing agency delivering SEO, paid media, web design, and conversion optimization.\"}"}}],["$","script","2",{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$11"}}],["$","script","3",{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://www.kinexisdigital.com/en\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Digital Marketing Agency\"}]}"}}]],[["$","$L12",null,{"moduleIds":["app\\[locale]\\digital-marketing-agency\\page.tsx -> @/components/pages/AgencyHubPageClient"]}],"$L13"]]
