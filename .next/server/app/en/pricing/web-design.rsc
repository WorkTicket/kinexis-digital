11:T9d7,{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Do you offer payment plans?","acceptedAnswer":{"@type":"Answer","text":"Yes. Most projects split 50% at kickoff and 50% at launch. Larger builds can be phased by milestone."}},{"@type":"Question","name":"Which platforms do you build on?","acceptedAnswer":{"@type":"Answer","text":"We work primarily in Next.js and Webflow depending on your needs. We recommend the stack that fits your team, budget, and growth plans."}},{"@type":"Question","name":"Is hosting included?","acceptedAnswer":{"@type":"Answer","text":"Hosting is separate. We help you choose and configure the right setup, usually Vercel, Netlify, or Webflow hosting."}},{"@type":"Question","name":"How long does a typical project take?","acceptedAnswer":{"@type":"Answer","text":"A standard Business Site build takes 6 to 10 weeks from kickoff to launch. Landing page projects run 2 to 3 weeks. Custom builds with e-commerce or complex integrations run 10 to 16 weeks depending on scope."}},{"@type":"Question","name":"Will my site be optimized for SEO?","acceptedAnswer":{"@type":"Answer","text":"Yes. Every build includes a technical SEO foundation: semantic HTML structure, correct heading hierarchy, meta tags, schema markup, sitemap, and Core Web Vitals optimization. This is not an add-on. It is part of every project."}},{"@type":"Question","name":"What do I need to provide for the project to start?","acceptedAnswer":{"@type":"Answer","text":"Your existing brand assets (logo, fonts, color palette if you have them), access to your current hosting and domain, example sites you like, and a brief describing your core services and target customers. We handle the rest including copy guidance, photography direction, and technical setup."}},{"@type":"Question","name":"Can you redesign an existing site without starting over?","acceptedAnswer":{"@type":"Answer","text":"Sometimes. If the technical foundation is sound, a redesign is faster and cheaper than a full rebuild. We audit your current site in week one and give you a clear recommendation. We will not push a full rebuild if a focused redesign achieves your goals."}},{"@type":"Question","name":"Do you provide post-launch support?","acceptedAnswer":{"@type":"Answer","text":"All projects include 30 days of post-launch support covering bug fixes and minor adjustments. Ongoing maintenance retainers and CRO testing sprints are available separately for clients who want continuous improvement."}}]}6:[[["$","script","0",{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Organization\",\"@id\":\"https://www.kinexisdigital.com/#organization\",\"name\":\"KINEXIS Digital\",\"url\":\"https://www.kinexisdigital.com\",\"logo\":{\"@type\":\"ImageObject\",\"url\":\"https://www.kinexisdigital.com/assets/logos/KINEXIS_icon_logo.webp\",\"width\":512,\"height\":512},\"description\":\"Digital marketing agency specializing in SEO, paid media, web design, CRO, and analytics for local businesses, SaaS companies, and enterprise organizations.\",\"sameAs\":[\"https://www.linkedin.com/company/kinexisdigital\"],\"contactPoint\":{\"@type\":\"ContactPoint\",\"contactType\":\"sales\",\"email\":\"hello@kinexisdigital.com\",\"availableLanguage\":[\"English\",\"Spanish\"]}}"}}],["$","script","1",{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Service\",\"@id\":\"https://www.kinexisdigital.com/en/pricing/web-design#service\",\"name\":\"Web Design Services Pricing\",\"description\":\"Web design pricing for conversion-focused business websites. Landing pages from $3,500, business sites $8K to $35K with Core Web Vitals, CMS setup, and analytics included.\",\"provider\":{\"@id\":\"https://www.kinexisdigital.com/#organization\"},\"url\":\"https://www.kinexisdigital.com/en/pricing/web-design\",\"areaServed\":{\"@type\":\"Country\",\"name\":\"Worldwide\"}}"}}],["$","script","2",{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$11"}}],"$L12"],"$L13"]
