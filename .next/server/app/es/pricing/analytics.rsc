11:T83a,{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Is there a setup fee?","acceptedAnswer":{"@type":"Answer","text":"Most engagements include onboarding and strategy in month one. We quote it upfront. No surprise charges on the first invoice."}},{"@type":"Question","name":"Do you require a long-term contract?","acceptedAnswer":{"@type":"Answer","text":"No. Month to month. Results should earn your business, not a contract clause."}},{"@type":"Question","name":"What affects my price?","acceptedAnswer":{"@type":"Answer","text":"Setup projects are billed separately from ongoing reporting retainers."}},{"@type":"Question","name":"Can I start with a smaller plan and upgrade?","acceptedAnswer":{"@type":"Answer","text":"Yes. Many clients start on Starter and move up once momentum builds. We plan the upgrade path so you are not rebuilding from scratch."}},{"@type":"Question","name":"¿Con qué herramientas analíticas trabajan?","acceptedAnswer":{"@type":"Answer","text":"GA4, Google Tag Manager, Looker Studio, HubSpot, Salesforce y analítica nativa de plataformas de anuncios. Construimos dashboards en la herramienta que tu equipo ya usa o recomendamos la mejor opción."}},{"@type":"Question","name":"¿Cuánto cuesta la gestión de analítica de marketing?","acceptedAnswer":{"@type":"Answer","text":"Retainers van de $1,500 a $3,500 al mes según cantidad de canales, integraciones y complejidad de reportes. Proyectos únicos de setup GA4 y dashboards parten en $3,000."}},{"@type":"Question","name":"¿Pueden corregir nuestro setup GA4 existente?","acceptedAnswer":{"@type":"Answer","text":"Sí. La mayoría de cuentas que auditamos tienen eventos faltantes, conversiones duplicadas o conexiones CRM rotas. Normalmente resolvemos problemas core de tracking en 2 a 3 semanas."}},{"@type":"Question","name":"¿Reportan ROI y ROAS?","acceptedAnswer":{"@type":"Answer","text":"Sí, cuando la integración CRM está en su lugar. Reportamos costo por lead, costo por adquisición, ROAS por canal y valor de pipeline atribuido a campañas de marketing."}}]}6:[[["$","script","0",{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Organization\",\"name\":\"KINEXIS Digital\",\"url\":\"https://www.kinexisdigital.com\",\"logo\":\"https://www.kinexisdigital.com/logo.png\",\"description\":\"Digital marketing agency specializing in SEO, paid media, web design, CRO, and analytics for local businesses, SaaS companies, and enterprise organizations.\",\"sameAs\":[\"https://www.linkedin.com/company/kinexisdigital\"],\"contactPoint\":{\"@type\":\"ContactPoint\",\"contactType\":\"sales\",\"availableLanguage\":[\"English\",\"Spanish\"]}}"}}],["$","script","1",{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Service\",\"name\":\"Marketing Analytics Services Pricing\",\"description\":\"Transparent marketing analytics pricing with clear tiers and deliverables. No hidden fees. No vague retainers.\",\"provider\":{\"@type\":\"Organization\",\"name\":\"KINEXIS Digital\",\"url\":\"https://www.kinexisdigital.com\"},\"url\":\"https://www.kinexisdigital.com/es/pricing/analytics\",\"areaServed\":\"Worldwide\"}"}}],["$","script","2",{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$11"}}],["$","script","3",{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://www.kinexisdigital.com/es\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Services\",\"item\":\"https://www.kinexisdigital.com/es/services\"},{\"@type\":\"ListItem\",\"position\":3,\"name\":\"Marketing Analytics Services\",\"item\":\"https://www.kinexisdigital.com/es/services/analytics\"},{\"@type\":\"ListItem\",\"position\":4,\"name\":\"Marketing Analytics Pricing\"}]}"}}]],