6:[[["$","script","0",{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Organization\",\"@id\":\"https://www.kinexisdigital.com/#organization\",\"name\":\"KINEXIS Digital\",\"url\":\"https://www.kinexisdigital.com\",\"logo\":{\"@type\":\"ImageObject\",\"url\":\"https://www.kinexisdigital.com/assets/logos/KINEXIS_icon_logo.webp\",\"width\":512,\"height\":512},\"description\":\"Digital marketing agency specializing in SEO, paid media, web design, CRO, and analytics for local businesses, SaaS companies, and enterprise organizations.\",\"sameAs\":[\"https://www.linkedin.com/company/kinexisdigital\"],\"contactPoint\":{\"@type\":\"ContactPoint\",\"contactType\":\"sales\",\"email\":\"hello@kinexisdigital.com\",\"availableLanguage\":[\"English\",\"Spanish\"]}}"}}],["$","script","1",{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://www.kinexisdigital.com/es\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Case Studies\",\"item\":\"https://www.kinexisdigital.com/es/case-studies\"}]}"}}]],[["$","$L11",null,{"moduleIds":["app\\[locale]\\case-studies\\page.tsx -> @/components/pages/CaseStudiesPageClient"]}],["$","$L12",null,{"content":{"heroTitleLine1":"Crecimiento real.","heroTitleGradient":"Números reales.","heroSubtitle":"Tres casos de estudio verificados en servicios del hogar y tecnología. Cada uno incluye estrategia, ejecución y resultados reales. Sin métricas vanidosas. Solo ingresos.","featuredCaseStudyLabel":"Caso de Estudio Destacado","beforeVsAfterLabel":"Antes vs Después","timelineLabel":"Cronograma","readFullCaseStudy":"Leer Caso de Estudio Completo","clientResultsLabel":"Resultados de Clientes","clientResultsTitle":"Resultados comprobados.","clientResultsDescription":"Filtra por industria para encontrar resultados relevantes para tu negocio. Cada estudio incluye estrategia, ejecución y resultados verificados.","noCaseStudiesMessage":"Aún no hay casos de estudio en esta industria. Vuelve pronto.","trafficLabel":"Tráfico","leadsLabel":"Leads","revenueLabel":"Ingresos","viewCaseStudy":"Ver Caso de Estudio","whatDataShowsLabel":"Lo que Muestran los Datos","whatDataShowsTitle":"Los servicios combinados superan las tácticas sueltas.","whatDataShowsDescription":"Los mejores resultados llegan cuando dos o más servicios trabajan juntos. Los enfoques de una sola táctica tienen un techo. Los sistemas conectados se refuerzan entre sí.","ctaTitle":"¿Listo para ser nuestro próximo caso de estudio?","ctaSubtitle":"Cada cliente recibe el mismo sistema,|estrategia y compromiso con resultados medibles.","ctaButton":"Comienza Tu Historia de Crecimiento","industries":["Todos","Servicios del Hogar","Tecnología"],"caseStudies":[{"slug":"landscaping-company-growth","title":"Empresa de Jardinería","industry":"Servicios del Hogar","headline":"Crecimiento de Leads 4.8X","trafficLift":"+1,290%","leadLift":"+380%","revenueLift":"+$14,300/mes","timeline":"10 meses","summary":"Transformamos un negocio de jardinería dependiente de referidos en una máquina de generación de leads mediante SEO local y optimización de conversión.","services":["SEO Local","Diseño Web","Optimización de Conversión","Marketing de Contenido"],"featured":true,"metrics":[{"label":"Leads Calificados","from":10,"to":48,"suffix":"/mes"},{"label":"Tráfico Orgánico","from":420,"to":5840,"suffix":"/mes"},{"label":"Tasa de Conversión","from":1.8,"to":8.4,"suffix":"%","decimals":1},{"label":"Ingresos Influenciados","from":4200,"to":18500,"prefix":"$$","suffix":"/mes"}]},{"slug":"plumbing-company-growth","title":"Empresa de Plomería","industry":"Servicios del Hogar","headline":"327% Más Llamadas de Emergencia","trafficLift":"+410%","leadLift":"+327%","revenueLift":"+$14,200/mes","timeline":"8 meses","summary":"Una empresa familiar de plomería superó la dependencia de anuncios pagados dominando la búsqueda local para servicios de emergencia.","services":["SEO Local","Diseño Web","Seguimiento de Llamadas","Gestión de Reputación"],"featured":false,"metrics":[{"label":"Llamadas de Emergencia","from":22,"to":94,"suffix":"/mes"},{"label":"Trabajos Reservados","from":18,"to":67,"suffix":"/mes"},{"label":"Tráfico Orgánico","from":200,"to":1020,"suffix":"/mes"},{"label":"Interacciones GBP","from":340,"to":8400,"suffix":"/mes"}]},{"slug":"saas-platform-growth","title":"Plataforma SaaS","industry":"Tecnología","headline":"Solicitudes de Demo 5.9X","trafficLift":"+482%","leadLift":"+490%","revenueLift":"+$24,500/mes","timeline":"8 meses","summary":"Una empresa SaaS B2B escaló las solicitudes de demo calificadas de 32 a 189 por mes mediante estrategia de contenido y optimización de conversión.","services":["Marketing de Contenido","SEO Técnico","CRO","Analítica"],"featured":false,"metrics":[{"label":"Solicitudes de Demo","from":32,"to":189,"suffix":"/mes"},{"label":"Tráfico Orgánico","from":950,"to":5520,"suffix":"/mes"},{"label":"SQLs","from":14,"to":78,"suffix":"/mes"},{"label":"MRR","from":8500,"to":33000,"prefix":"$$","suffix":"/mes"}]}],"growthPatterns":[{"combo":"SEO + CRO","lift":"+317%","desc":"Tráfico × conversión = ingresos"},{"combo":"SEO + Diseño Web","lift":"+423%","desc":"Rankings + experiencia = leads"},{"combo":"Anuncios + CRO","lift":"+276%","desc":"Tráfico pagado + páginas optimizadas = ROAS"},{"combo":"Email + CRM","lift":"+188%","desc":"Retención × valor de vida"}],"metricWall":[{"label":"Ingresos Generados","value":"$$14.7M+"},{"label":"Aumento Promedio de Tráfico","value":"+287%"},{"label":"Total de Leads Generados","value":"28.3K+"},{"label":"Aumento Promedio de Conversión","value":"+193%"}]}}]]]
