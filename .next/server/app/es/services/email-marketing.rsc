14:["$","$L1b",null,{"slug":"email-marketing","locale":"es","data":{"slug":"email-marketing","locale":"es","visualVariant":"dashboard","visualizationSection":"WhyKinexus","hero":{"label":"Servicios Email Marketing","line1":"Email que mueve","line2":"prospectos hacia el sí.","subtitle":"Secuencias y campañas ligadas a dónde está cada lead en tu pipeline.|No otro newsletter mensual que nadie lee.","ctaLabel":"Inicia Tu Estrategia de Email"},"sectionOrder":["ServiceOverview","WhyKinexus","EmailSequences","Automation","ListGrowth","Process","Deliverables","Proof","Results","PricingTeaser"],"overview":{"headline":"Por Qué la Mayoría de Programas Email Generan Aperturas pero No Ingresos","problem":"Recolectar direcciones de email es fácil. Convertir esas direcciones en llamadas agendadas y deals cerrados requiere secuencias construidas alrededor de cómo tus compradores deciden realmente.","solution":"Automatización Email Mapeada a Tu Ciclo de Ventas","problemPoints":["Los newsletters salen mensualmente sin conexión con dónde está cada suscriptor en el proceso de compra.","Las automatizaciones se detienen después de un email de bienvenida en lugar de nutrir leads semanas o meses.","La segmentación es básica o inexistente, y todos reciben el mismo mensaje sin importar interés.","Problemas de deliverability mandan emails a spam porque las listas nunca se limpiaron ni calentaron bien."],"solutionPoints":["Secuencias de bienvenida, nutrición y re-engagement ligadas a ofertas específicas y etapas del comprador.","Segmentación por fuente de lead, comportamiento y engagement para mantener mensajes relevantes.","Pruebas A/B en subject lines, horarios de envío y CTAs para mejorar aperturas y clics con el tiempo.","Setup de deliverability incluyendo SPF, DKIM, DMARC e higiene de lista para proteger llegada a inbox."]},"whyKinexus":{"headline":"El Sistema de Email Revenue Kinexus","subtitle":"Secuencias comportamentales, entregabilidad primero y cada flujo ligado al pipeline — no a tasas de apertura.","points":[{"title":"Infraestructura de ingresos","description":"Secuencias que mueven leads hacia llamadas reservadas."},{"title":"Segmentación por comportamiento","description":"El mensaje correcto según señales de engagement."},{"title":"Entregabilidad primero","description":"Higiene de lista y reputación antes de volumen."},{"title":"Atribución de ingresos","description":"Cada secuencia ligada a pipeline, no solo opens."}]},"proof":{"caseStudy":{"client":"Plataforma SaaS","challenge":"12,000 suscriptores con solo un email de bienvenida automatizado y cero demos atribuidas a email.","outcome":"42% apertura promedio en secuencias de nurture y +180% en reservas de demo.","href":"/case-studies/saas-platform-growth"}},"results":{"title":"Results we track","subtitle":"Email outcomes from recent client programs.","metrics":[{"metric":"38%","label":"avg. open rate · optimized sequences"},{"metric":"8x","label":"ROAS on email vs. paid channels"},{"metric":"+180%","label":"revenue from automated flows · 90 days"}]},"process":{"title":"El proceso de construcción.","subtitle":"De la estrategia a campañas en vivo,|cada fase tiene un entregable claro.","steps":[{"title":"Auditoría y Estrategia","desc":"Revisar infraestructura de email actual, salud de la lista y rendimiento pasado. Mapear estrategia de ciclo de vida completa.","metric":"Estrategia de ciclo de vida completa en la semana 1"},{"title":"Segmentación y Limpieza","desc":"Segmentar audiencia por comportamiento y engagement. Eliminar inactivos para proteger la reputación del remitente.","metric":"Prom. 34% de mejora en salud de lista"},{"title":"Construcción de Campañas y Automatización","desc":"Secuencias de bienvenida, flujos de nutrición, carritos abandonados. Todo probado antes de publicar.","metric":"5+ secuencias automatizadas por cliente"},{"title":"Diseño y Copy","desc":"Cada email diseñado para impulsar acción, desde la línea de asunto hasta el botón CTA.","metric":"Prom. 42% de tasa de apertura en campañas"},{"title":"Probar, Reportar y Optimizar","desc":"Pruebas A/B de asuntos, horarios de envío y formatos. Reportes semanales con recomendaciones claras.","metric":"18% de crecimiento de ingresos mes a mes"}]},"deliverables":{"title":"Entregables Email Marketing","subtitle":"Estrategia, automatización y campañas que impulsan pipeline, no solo aperturas.","items":[{"title":"Estrategia Email y Calendario","description":"Plan de segmentación, frecuencia de envío, temas de campaña y mapa de automatización alineado a tu embudo."},{"title":"Construcción de Flujos de Automatización","description":"Serie de bienvenida, secuencias de nutrición, follow-ups de leads abandonados y flujos de retención post-venta."},{"title":"Copy y Diseño de Campañas","description":"Copy de email, subject lines y plantillas responsive móvil para broadcasts y automatizaciones."},{"title":"Segmentación y Gestión de Lista","description":"Tags, segmentos y reglas de supresión basadas en comportamiento, fuente y nivel de engagement."},{"title":"Programa de Pruebas A/B","description":"Pruebas estructuradas en subject lines, preview text, CTAs y horarios de envío con resultados documentados."},{"title":"Reportes de Rendimiento y Deliverability","description":"Tasas de apertura, clics, conversiones, bajas y monitoreo de inbox placement mensualmente."}]},"serviceSections":{"EmailSequences":{"id":"email-sequences","headline":"Flujo de Secuencia de Email","subheadline":"Cada email de la secuencia cumple un propósito específico, desde la bienvenida hasta el cierre.|Programado y probado para máximo engagement.","visualVariant":"dashboard","points":[{"title":"Email de bienvenida + entrega de lead magnet","description":"Día 0","metric":"68%"},{"title":"Email de valor: contenido educativo","description":"Día 3","metric":"52%"},{"title":"Caso de estudio / prueba social","description":"Día 7","metric":"48%"},{"title":"Oferta suave: agendar una llamada","description":"Día 14","metric":"42%"}],"tableHeaders":{"col1":"Email","col2":"Momento","col3":"Apertura"}},"Automation":{"id":"automation","headline":"Automatización que funciona 24/7.","subheadline":"Cada disparador, acción y condición mapeados para que tu sistema de|email funcione sin intervención manual.","visualVariant":"chart","points":[{"title":"Secuencias de Bienvenida","description":"Auto-respuestas que se activan cuando alguien se suscribe o descarga un lead magnet","metric":"Active"},{"title":"Flujos de Nutrición","description":"Secuencias multitoque que educan, generan confianza y crean oportunidades de reserva","metric":"Active"},{"title":"Carrito Abandonado","description":"Flujos de recuperación que traen de vuelta a visitantes que se fueron antes de convertir","metric":"Active"},{"title":"Disparadores de Ciclo de Vida","description":"Emails basados en comportamiento según aperturas, clics, compras e inactividad","metric":"Active"}],"tableHeaders":"$undefined"},"ListGrowth":{"id":"list-growth","headline":"Métricas de rendimiento.","subheadline":"Números reales de campañas reales,|no benchmarks de la industria sacados de blogs.","visualVariant":"comparison","points":[{"title":"Tasa de Apertura Prom.","description":"vs. 22% promedio de la industria","metric":"38%"},{"title":"Tasa de Clic","description":"vs. 2.5% promedio de la industria","metric":"4.2%"},{"title":"Ingresos por Email","description":"En todas las campañas","metric":"0.42"},{"title":"Tasa de Reserva","description":"De email a llamada agendada","metric":"11%"}],"tableHeaders":"$undefined"}},"faq":[{"question":"¿Con qué plataformas de email trabajan?","answer":"Trabajamos con Klaviyo, ActiveCampaign, Mailchimp, HubSpot, Drip, ConvertKit y la mayoría de los ESPs principales. Si ya tienes una plataforma, la optimizamos. Si empiezas desde cero, recomendamos la mejor para tu modelo de negocio."},{"question":"¿Cómo hacen crecer mi lista de email?","answer":"El crecimiento de la lista es una estrategia, no un accidente. Combinamos lead magnets, formularios de opt-in optimizados, landing pages e integración con tráfico de pago para agregar suscriptores calificados que no dañen tu entregabilidad."},{"question":"¿Qué tasas de apertura puedo esperar?","answer":"Nuestros clientes promedio ven tasas de apertura del 38% frente al 22% del promedio del sector. Los resultados dependen de la salud de la lista, la estrategia de asunto y la segmentación. Auditamos todo esto antes de hacer cualquier proyección."},{"question":"¿Manejan el copywriting y el diseño de emails?","answer":"Sí. Nuestro equipo gestiona la estrategia, el copy y el diseño para cada campaña y secuencia que construimos. Tú revisas y apruebas antes de que se envíe nada. La mayoría de los clientes no necesitan escribir una sola palabra."},{"question":"¿Con qué frecuencia debería enviar emails a mi lista?","answer":"Depende de tu audiencia y de lo que vendes. La mayoría de nuestros clientes comienzan con 2-4 emails al mes y aumentan cuando las tasas de apertura confirman que la lista está comprometida. No recomendamos frecuencia por el simple hecho de hacerlo."},{"question":"¿Con qué plataformas email trabajan?","answer":"Trabajamos con HubSpot, ActiveCampaign, Klaviyo, Mailchimp y ConvertKit según tu tipo de negocio y necesidades de integración. Recomendamos la mejor opción en tu llamada estratégica."},{"question":"¿Cuánto cuesta la gestión de email marketing?","answer":"Retainers van de $2,000 a $5,000 al mes según tamaño de lista, cantidad de automatizaciones y frecuencia de campañas. Proyectos con setup pesado y nuevas automatizaciones pueden tener tarifa única de onboarding."},{"question":"¿Qué tan rápido pueden lanzar automatizaciones email?","answer":"Secuencias de bienvenida y nutrición básica suelen lanzarse en 2 a 3 semanas. Automatización completa de embudo con segmentación y múltiples secuencias toma 4 a 6 semanas."},{"question":"¿Pueden mejorar nuestra deliverability email?","answer":"Sí. Auditamos registros SPF, DKIM y DMARC, limpiamos tu lista, configuramos calentamiento correcto para dominios nuevos y monitoreamos tasas de quejas spam. La mayoría de problemas de deliverability se resuelve en 2 a 4 semanas de correcciones."}],"answerBlock":"Los servicios email marketing incluyen estrategia de lista, flujos de automatización, creación de campañas, segmentación, pruebas A/B y monitoreo de deliverability. Retainers parten en $2,000 a $5,000 al mes según tamaño de lista y complejidad de automatización. Secuencias de bienvenida suelen lanzarse en 2 a 3 semanas.","comparison":{"title":"Email Marketing: Plataforma DIY vs. Programa Gestionado","subtitle":"Qué obtienes con un programa email gestionado versus operarlo tú mismo.","layout":"stacked","columns":[{"header":"DIY en Mailchimp / HubSpot"},{"header":"KINEXIS Email Marketing","highlight":true}],"rows":[{"label":"Estrategia","values":["Broadcasts ad hoc","Plan de automatización mapeado al embudo"]},{"label":"Copy y diseño","values":["Equipo interno o plantillas","Copy profesional y plantillas custom"]},{"label":"Segmentación","values":["Listas básicas","Segmentos por comportamiento y fuente"]},{"label":"Pruebas","values":["Raras o ninguna","Programa continuo de pruebas A/B"]},{"label":"Deliverability","values":["A menudo descuidada","Monitoreo activo e higiene de lista"]},{"label":"Inversión de tiempo","values":["5 a 10 horas/semana internamente","Ejecución completamente gestionada"]}]}},"breadcrumbs":[{"name":"Home","url":"/"},{"name":"Services","url":"/services"},{"name":"Email Marketing Services"}],"relatedLinks":{"services":[{"href":"/services/funnels","label":"Funnels & CRO"},{"href":"/services/content-marketing","label":"Content Marketing"},{"href":"/pricing/email-marketing","label":"Email Marketing Pricing"}],"caseStudies":[{"href":"/case-studies/saas-platform-growth","label":"5.9X Demos · SaaS Platform"},{"href":"/case-studies/landscaping-company-growth","label":"4.8X Leads · Landscaping Co."}],"blog":[{"href":"/blog/email-nurture-sequences-that-book-calls","label":"Email Nurture Sequences"},{"href":"/blog/automated-nurture-sequences","label":"Automated Nurture Sequences"}],"solutions":[]}}]
