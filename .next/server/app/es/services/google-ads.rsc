14:["$","$L1a",null,{"slug":"google-ads","locale":"es","data":{"slug":"google-ads","locale":"es","visualVariant":"dashboard","visualizationSection":"WhyKinexus","hero":{"label":"Gestión Google Ads","line1":"Google Ads que protegen","line2":"tu margen, no el de Google.","subtitle":"Search, Shopping y PMax para leads calificados.|Corregimos estructura de cuenta y tracking que inflan el costo por lead.","ctaLabel":"Auditar Tu Cuenta de Anuncios"},"sectionOrder":["ServiceOverview","WhyKinexus","CampaignArchitecture","KeywordResearch","LandingPages","ConversionTracking","Process","Deliverables","Proof","Results","PricingTeaser"],"overview":{"headline":"Por Qué las Cuentas Google Ads Desperdician Presupuesto","problem":"Google facilita gastar dinero y dificulta saber qué realmente impulsa ingresos. La mayoría de cuentas que auditamos tienen problemas estructurales que inflan el costo por lead.","solution":"Google Ads Construido para Quality Score y ROAS","problemPoints":["Keywords broad match y recomendaciones auto-aplicadas inflan gasto en búsquedas irrelevantes.","El tracking de conversiones cuenta formularios y page views en lugar de leads calificados.","La estructura mezcla brand, competidor y términos genéricos sin segmentación adecuada.","Las landing pages no coinciden con la intención del anuncio, baja el Quality Score y sube el CPC."],"solutionPoints":["Arquitectura de campañas que separa keywords de brand, competidor y genéricas de alta intención.","Gestión de keywords negativas y revisiones de search terms para cortar gasto desperdiciado cada semana.","Alineación de copy y landing pages que mejora Quality Score y reduce CPC.","Estrategias de puja ligadas a datos de conversión offline cuando tu ciclo de venta va más allá del clic."]},"whyKinexus":{"headline":"El Marco de Campañas Kinexus","subtitle":"Estructura por intención, disciplina semanal de términos de búsqueda y pujas ligadas a leads que ventas cierra.","points":[{"title":"Arquitectura por intención","description":"Marca, competencia y términos genéricos en campañas separadas."},{"title":"Disciplina semanal","description":"Palabras negativas y revisiones de consultas cada semana."},{"title":"Quality Score como palanca","description":"Alineación de anuncios y landing pages reduce CPC."},{"title":"Optimización respaldada por CRM","description":"Las pujas optimizan hacia leads calificados confirmados."}]},"proof":{"caseStudy":{"client":"Empresa de Plomería","challenge":"La agencia anterior ignoraba las llamadas como conversiones.","outcome":"+327% llamadas de emergencia con 65% reducción de CPL.","href":"/case-studies/plumbing-company-growth"}},"results":{"title":"Results we track","subtitle":"Google Ads outcomes from recent client programs.","metrics":[{"metric":"327%","label":"emergency calls · Plumbing Co., 8 mo"},{"metric":"65%","label":"CPL reduction · same client"},{"metric":"4.2x","label":"ROAS on high-intent Search campaigns"}]},"process":{"title":"El sistema de anuncios en 5 fases.","subtitle":"Cada campaña sigue un ciclo de optimización estructurado, desde la auditoría inicial hasta el escalado, para que el rendimiento se acumule con el tiempo en lugar de estancarse tras la semana de lanzamiento.","steps":[{"title":"Auditoría y Reestructuración","desc":"Revisión de campañas, keywords y conversiones con plan de rebuild.","metric":"Auditoría completa en semana 1"},{"title":"Keywords y Negativas","desc":"Objetivos de alta intención y listas negativas.","metric":"240+ términos revisados semanalmente"},{"title":"Alineación Anuncio-Landing","desc":"Anuncios responsivos, extensiones y landing pages alineadas.","metric":"8.2 Quality Score prom."},{"title":"Tracking y Lanzamiento","desc":"GA4, conversiones mejoradas y tracking de llamadas verificados.","metric":"Activo en 14 días"},{"title":"Optimización Semanal","desc":"Minería de términos, pujas y pacing ligados a leads calificados.","metric":"ROAS reportado semanalmente"}]},"deliverables":{"title":"Entregables de Gestión Google Ads","subtitle":"Todo lo necesario para operar campañas Search, Shopping y PMax rentables.","items":[{"title":"Auditoría y Reestructuración de Cuenta","description":"Revisión completa de campañas, ad groups, keywords, match types y conversion actions con plan de reconstrucción."},{"title":"Investigación de Keywords y Listas Negativas","description":"Keywords de alta intención más listas negativas continuas para bloquear tráfico irrelevante."},{"title":"Gestión de Copy y Extensiones","description":"Responsive search ads, callouts, sitelinks y structured snippets probados con cadencia regular."},{"title":"Configuración Performance Max y Shopping","description":"Optimización de feed, asset groups, señales de audiencia y estructura de listing groups para e-commerce."},{"title":"Tracking de Conversiones y Atribución","description":"GA4, Google Tag Manager, enhanced conversions e integración CRM para tracking preciso de leads."},{"title":"Optimización Semanal y Reportes","description":"Ajustes de pujas, pacing de presupuesto, revisiones de search terms y reportes mensuales de ROAS y CPL."}]},"serviceSections":{"CampaignArchitecture":{"id":"campaign-architecture","headline":"La asignación de presupuesto es una estrategia. No un detalle menor.","subheadline":"Asignamos gasto según lo que cada canal está devolviendo realmente, no según lo que funcionó el trimestre pasado. Los canales con alto ROAS reciben más presupuesto, los de bajo rendimiento se reestructuran o se eliminan, y cada reasignación se documenta con una justificación clara.","visualVariant":"dashboard","points":[{"title":"Búsqueda (Alta Intención)","description":"Campaña por intención","metric":"Active"},{"title":"Shopping (Producto)","description":"Campaña por intención","metric":"Active"},{"title":"Retargeting","description":"Campaña por intención","metric":"Active"},{"title":"Display (Awareness)","description":"Campaña por intención","metric":"Active"}],"tableHeaders":{"col1":"Fuente","col2":"Enfoque","col3":"Estado"}},"KeywordResearch":{"id":"keyword-research","headline":"Palabras Clave y Negativas","subheadline":"Objetivos de alta intención.","visualVariant":"chart","points":[{"title":"Brand Terms","description":"Protege búsquedas de marca","metric":"4.2x"},{"title":"Commercial Intent","description":"Consultas comerciales","metric":"3.6x"},{"title":"Negative Lists","description":"Bloqueo semanal","metric":"-32%"},{"title":"Minería de términos","description":"Consultas ganadoras promovidas, gasto cortado cada semana","metric":"240+ revisadas"}],"tableHeaders":"$undefined"},"LandingPages":{"id":"landing-pages","headline":"Anuncios y landing pages que coinciden.","subheadline":"Cuando la promesa del anuncio llega hasta la página de agradecimiento,|más personas reservan y menos leads se pierden.","visualVariant":"chart","points":[{"title":"Segmentación de audiencia","description":"Datos de primera parte y lookalikes llegan a compradores con intención demostrada.","metric":"Lookalikes + CRM"},{"title":"Coherencia de mensaje","description":"Las landing pages repiten el titular del anuncio para mejorar Quality Score y conversión.","metric":"8.2 Quality Score prom."},{"title":"Reglas de puja que protegen margen","description":"Reglas automatizadas cortan el gasto desperdiciado antes de que se acumule.","metric":"32% menos gasto perdido"},{"title":"Escala con límites","description":"El presupuesto crece solo cuando el ROAS se mantiene en tu objetivo.","metric":"4.5x ROAS prom."}],"tableHeaders":{"col1":"Palanca de conversión","col2":"Enfoque","col3":"Resultado"}},"ConversionTracking":{"id":"conversion-tracking","headline":"Panel de ROAS","subheadline":"Una vista en tiempo real del rendimiento en cada canal: gasto, ROAS y tasa de conversión, actualizados al instante para que las decisiones se tomen con datos de hoy, no del informe de la semana pasada.","visualVariant":"dashboard","points":[{"title":"Google Search","description":"escalando","metric":"Testing"},{"title":"Google PMax","description":"optimizando","metric":"Testing"},{"title":"Meta Ads","description":"escalando","metric":"Testing"},{"title":"LinkedIn","description":"probando","metric":"Testing"}],"tableHeaders":{"col1":"Canal","col2":"Estado","col3":"ROAS"}}},"faq":[{"question":"What budget do I need to get started?","answer":"Most clients invest $2,500 to $15,000 per month in management plus ad spend. We tailor scope to your goals and provide clear pricing after a strategy call."},{"question":"How quickly will I see results?","answer":"Paid media produces data within days and meaningful optimization within 2 to 4 weeks. ROAS typically improves significantly by month 2 or 3 as we refine targeting and creative."},{"question":"Do you require long-term contracts?","answer":"No. We work month to month because results should earn retention, not contract lock-in."},{"question":"How do you report performance?","answer":"Weekly optimization notes and monthly dashboards covering spend, ROAS, CPL, conversion rate, and revenue attribution where tracking allows."},{"question":"Do you manage Performance Max campaigns?","answer":"Yes. We build and optimize PMax with proper asset groups, audience signals, and feed data. We also monitor search term insights to prevent PMax from cannibalizing branded Search traffic."},{"question":"Will I own my Google Ads account?","answer":"Always. We work inside your account with full admin access. If you leave, you keep every campaign, keyword list, and conversion setup we built."},{"question":"Which ad platforms do you manage?","answer":"Google Ads, Meta, LinkedIn, and Microsoft Ads. We recommend the mix based on where your buyers actually convert, not platform hype."},{"question":"Do you set up conversion tracking?","answer":"Yes. GA4, GTM, call tracking, and offline conversion import are standard in week one. We do not optimize blind."},{"question":"Can you work with our in-house team?","answer":"Yes. We collaborate with internal marketers, other agencies, and fractional leaders. We can lead the program or fill a specific channel gap."},{"question":"What industries do you serve?","answer":"Home services, healthcare, professional services, SaaS, e-commerce, and manufacturing. If your buyers search before they buy, we can usually help."},{"question":"¿Cuánto cuesta la gestión Google Ads?","answer":"Las tarifas de gestión parten en $1,500 al mes para cuentas bajo $10,000 de ad spend. Cuentas más grandes se cotizan al 12% al 15% del gasto. Tu presupuesto de anuncios se paga directo a Google. Recomendamos mínimo $3,000 mensuales de ad spend para reunir datos suficientes de optimización."},{"question":"¿Gestionan campañas Performance Max?","answer":"Sí. Construimos y optimizamos Performance Max con asset groups correctos, señales de audiencia y datos de feed para e-commerce. También monitoreamos search term insights y tráfico de brand para evitar que PMax canibalice tus campañas Search."},{"question":"¿Qué tan rápido veré resultados de Google Ads?","answer":"Las campañas Search suelen generar leads en la primera semana de lanzamiento. CPL estable y optimizado normalmente toma 30 a 45 días mientras refinamos keywords, negativas y pujas. Shopping y PMax pueden necesitar 2 a 3 semanas para que el algoritmo se estabilice."},{"question":"¿Seré dueño de mi cuenta Google Ads?","answer":"Siempre. Trabajamos dentro de tu cuenta con acceso admin completo. Si te vas, te quedas con cada campaña, lista de keywords y setup de conversiones que construimos."}],"answerBlock":"La gestión Google Ads incluye auditoría de cuenta, estructura de campañas, estrategia de keywords, copy de anuncios, gestión de pujas, mejora de Quality Score y tracking de conversiones para Search, Shopping y Performance Max. Las tarifas de gestión parten en $1,500 al mes más ad spend. La mayoría de cuentas estabiliza CPL en 30 a 45 días.","comparison":{"title":"Google Ads: Autogestionado vs. KINEXIS","subtitle":"Compara operar Google Ads in-house contra un equipo de gestión dedicado.","layout":"impact","columns":[{"header":"Autogestionado / Freelancer"},{"header":"KINEXIS Google Ads","highlight":true}],"rows":[{"label":"Estructura de cuenta","values":["Campañas planas, intención mezclada","Segmentada por intención y etapa del embudo"]},{"label":"Frecuencia de optimización","values":["Mensual o cuando se acaba el presupuesto","Revisiones semanales de search terms y pujas"]},{"label":"Tracking de conversiones","values":["Page views contados como conversiones","Tracking de leads calificados con sync CRM"]},{"label":"Enfoque en Quality Score","values":["Rara vez monitoreado","Alineación activa de anuncios y landing pages"]},{"label":"Experiencia Shopping / PMax","values":["Experiencia limitada en feed y assets","Gestión dedicada de campañas e-commerce"]},{"label":"Mejora típica de CPL","values":["Línea base o en aumento","Reducción del 20% al 40% en 90 días"]}]}},"breadcrumbs":[{"name":"Home","url":"/"},{"name":"Services","url":"/services"},{"name":"Google Ads Management"}],"relatedLinks":{"services":[{"href":"/services/ppc-management","label":"PPC Management"},{"href":"/services/seo","label":"SEO Services"},{"href":"/pricing/ppc-management","label":"PPC Pricing"}],"caseStudies":[{"href":"/case-studies/plumbing-company-growth","label":"327% Calls · Plumbing Co."},{"href":"/case-studies/landscaping-company-growth","label":"4.8X Leads · Landscaping Co."}],"blog":[{"href":"/blog/negative-keywords-guide","label":"Negative Keywords Guide"},{"href":"/blog/seo-vs-google-ads","label":"SEO vs Google Ads"}],"solutions":[{"href":"/solutions/google-ads-for-roofers","label":"Google Ads for Roofers"}]}}]
