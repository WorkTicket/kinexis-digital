zation","branding":"Branding","contentMarketing":"Content Marketing","emailMarketing":"Email Marketing & Automation","socialMedia":"Social Media Management","videoMarketing":"Video Marketing","analytics":"Analytics & Reporting","cro":"Conversion Rate Optimization","growthConsulting":"Growth Strategy & Consulting","content":"Content","webDesignShort":"Web Design","funnelsShort":"Funnels & CRO"},"footer":{"tagline":"We turn inconsistent traffic into predictable revenue systems.","navigation":"Navigation","services":"Services","contact":"Contact","copyright":"KINEXIS Digital. All rights reserved.","builtWith":"Built with strategy, not templates.","missionTitle":"We take on 8–10 clients at a time.","missionBody":"Focused engagements. Real results. No cookie-cutter playbooks.","privacy":"Privacy Policy","terms":"Terms of Service","locations":"Locations"},"common":{"bookStrategyCall":"Book a Strategy Call","scheduleStrategyCall":"Schedule a Strategy Call","learnAboutUs":"Learn About Us","viewAllServices":"View All Services","viewOurWork":"View Our Work","viewCaseStudy":"View Case Study","viewAllCaseStudies":"View All Case Studies","outcomeComparison":"Outcome comparison","getFreeAudit":"Get Free Audit","requestProposal":"Request Proposal","atAGlance":"At a Glance"},"language":{"label":"Language","en":"English","es":"Español (LATAM)"},"hero":{"line1":"WE DON'T","line2":"GENERATE LEADS.","line3":"WE BUILD","line3Highlight":"MARKET DOMINANCE.","subtitle":"The infrastructure that moves qualified traffic toward revenue: technical, creative, and strategic, built as one coordinated program.|Not a list of services. A system."},"revenueEngine":{"label":"The KINEXIS Framework","title":"Visibility → Traffic → Leads → Revenue","subtitle":"Four stages. Each one depends on the last. Skip one and the whole thing leaks.","liveTrajectory":"Live trajectory","stage":"Stage","trajectoryPeriod":"7-month trajectory","metricStart":"Start","metricCurrent":"Current","chartStart":"Start","chartEnd":"Now","stages":{"visibility":{"label":"Visibility","description":"Qualified visitors from search, social, and paid channels","tags":["SEO","Paid Ads","Social"]},"traffic":{"label":"Traffic","description":"Pages built to convert, wherever people find you","tags":["Landing Pages","Lead Magnets"]},"leads":{"label":"Leads","description":"Frictionless capture and strategic sales conversations","tags":["Forms","Discovery Calls"]},"revenue":{"label":"Revenue","description":"Predictable growth in recurring revenue and lifetime value","tags":["MRR","LTV"]}},"chartUnits":{"visibility":"impressions (K)","traffic":"sessions (K)","leads":"leads/mo","revenue":"$$K MRR"}},"servicesEcosystem":{"label":"Connected Services","title":"Services that work together.","subtitle":"SEO feeds content. Content feeds funnels. Funnels feed email. Run them separately and they perform like separate services. Build them as one program and each one amplifies the rest."},"featuredResults":{"label":"Proven Results","title":"Outcomes, not opinions.","subtitle":"Six verified client results. Strategy, execution timeline, and real revenue numbers. Documented and available on request.","cases":{"landscaping":{"category":"Home Services","title":"Landscaping Company","headline":"5X Revenue Growth","summary":"A complete website rebuild and local SEO campaign turned this business around. Revenue went from $2,000/mo to $11,500/mo in 8 months."},"dental":{"category":"Healthcare","title":"Dental Practice","headline":"340% More Patients","summary":"Multi-location dental practice. Local SEO overhaul and ad restructure drove new patient bookings from 45 to 198 per month."},"ecommerce":{"category":"Retail","title":"Premium E-Commerce Brand","headline":"4X Monthly Revenue","summary":"Brand repositioning and site rebuild lifted AOV from $85 to $238 and revenue from $12K to $45K per month."}}},"philosophy":{"label":"Why Clients Switch To KINEXIS","title":"You've been here before.","subtitle":"Another agency. Another promise. Another quarterly report full of impressions that don't touch your pipeline.","before":"Before","after":"After","agencyA":"Agency A","beforeItems":["Slow communication","No reporting","No transparency","Vanity metrics","Rotating account managers"],"afterItems":["Weekly reporting","Clear KPIs","Dedicated strategist","Revenue-focused metrics","Direct access to leadership"],"statusBefore":"Disconnected","statusAfter":"Revenue-aligned","dashboardBefore":"Q4 dashboard","dashboardAfter":"Live KPI board","pipelineLabel":"Pipeline value","pipelineBefore":"↓ 22%","pipelineAfter":"↑ 3.2×","statImpressions":"Impressions","statEngagement":"Engagement","statRevenue":"Revenue","beforeItemDetails":["Three-day email loops and vague updates. Urgent issues wait until your next scheduled call while ad spend keeps burning.","A PDF once a quarter, if you're lucky. No visibility into what's working, what's wasted, or what changed last week.","Black-box billing and unclear scope. You never know who's doing the work or where your budget actually goes.","They celebrate impressions and clicks while your pipeline stays flat. Activity looks busy. Revenue does not move.","Every quarter someone new owns your account. Context resets and you're re-explaining your business from scratch."],"afterItemDetails":["Every Monday: spend, leads, CPL, and pipeline in one digest. You always know where you stand and what's being optimized.","We agree on targets upfront: revenue, cost per lead, conversion rate. We report against them every week.","One senior strategist owns your account end-to-end. They know your business, market, and numbers. No handoffs.","We track what hits your P&L: qualified leads, close rate, ROAS, and LTV. Vanity metrics are context, never the headline.","Skip the ticket queue. When something matters, you're talking to decision-makers who can change direction fast."]},"cta":{"label":"Let's Talk","title":"Ready to Build a","titleHighlight":"Revenue System?","subtitle":"No deck. No