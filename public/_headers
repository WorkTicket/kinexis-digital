/.well-known/security.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=86400

/security.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=86400

# Crawler discovery files — short CDN cache for faster bot fetches
/sitemap.xml
  Cache-Control: public, s-maxage=3600, stale-while-revalidate=86400

/robots.txt
  Cache-Control: public, s-maxage=3600, stale-while-revalidate=86400

/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(self)
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  X-DNS-Prefetch-Control: on

# Locale-prefixed HTML — CDN cache to reduce Ahrefs TTFB / slow-page flags
/en/*
  Cache-Control: public, s-maxage=86400, stale-while-revalidate=604800

/es/*
  Cache-Control: public, s-maxage=86400, stale-while-revalidate=604800

# Static assets — 1-year immutable cache
/assets/*
  Cache-Control: public, max-age=31536000, immutable

/assets/*.webp
  Cache-Control: public, max-age=31536000, immutable
  Vary: Accept

/assets/*.avif
  Cache-Control: public, max-age=31536000, immutable
  Vary: Accept

/logo.png
  Cache-Control: public, max-age=31536000, immutable

# Next.js hashed static bundles — safe to cache forever
/_next/static/*
  Cache-Control: public, max-age=31536000, immutable

# Next.js image optimizer output
/_next/image*
  Cache-Control: public, max-age=31536000, immutable
  Vary: Accept

# Fonts are self-hosted by next/font — content-hashed filenames
/_next/static/media/*
  Cache-Control: public, max-age=31536000, immutable
